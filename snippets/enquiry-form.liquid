{% if section.settings.enable_enquiry %}
<div class="enquiry-modal">
  <div class="enquiry-content">
    <span class="close-button dt-sc-btn close-icon"></span>
    <span class="enquiry-content-inner">    
      <h4>{{ 'enquiry.form.sub_heading' | t }}</h4>
      {% form 'contact' %}
      {%- if form.posted_successfully? -%}
        <div class="contact-form-success-banner" style="background: #eaf8ee; border: 1px solid #34a853; border-radius: 8px; padding: 24px; text-align: center; margin-bottom: 24px;" tabindex="-1" autofocus>
          <div style="font-size: 32px; margin-bottom: 12px;">✅</div>
          <h3 style="color: #1b6631; font-size: 22px; margin: 0 0 10px 0; font-weight: 600;">Thank You! Your message has been sent successfully.</h3>
          <p style="color: #2c593a; font-size: 15px; margin: 0; line-height: 1.6;">We have received your enquiry and will get back to you as soon as possible.</p>
        </div>
      {%- elsif form.errors -%}
        <div class="form__message" style="color: red; margin-bottom: 15px;">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      {%- unless form.posted_successfully? -%}
      <input
             type="text"
             id="ContactFormName"
             name="contact[name]"
             placeholder="Name"
             required
             />
      <input
             type="email"
             id="ContactFormEmail"
             name="contact[email]"
             placeholder="Email"
             required
             />
      <input
             type="tel"
             id="ContactFormPhone"
             name="contact[phone]"
             placeholder="Phone"
             required
             />
      <textarea rows="7"
                id="ContactFormMsg"
                name="contact[body]"
                placeholder="Subject"
                required></textarea>
      <div class="enquiry-choose">
        <input
               type="radio"
               id="ContactViaEmail"
               name="contact[contact_preference]"
               value="Email"
               required
               />
        <label for="ContactViaEmail">{{ 'enquiry.form.by_email' | t }}</label>
        <input
               type="radio"
               id="contactFormViaPhone"
               name="contact[contact_preference]"
               value="Phone"
               />
        <label for="contactFormViaPhone">{{ 'enquiry.form.by_phone' | t }}</label>
        <input
               type="radio"
               id="contactFormViaBoth"
               name="contact[contact_preference]"
               value="Both"
               />
        <label for="contactFormViaBoth">{{ 'enquiry.form.by_both' | t }}</label>
      </div>
      <button type="submit" class="btn">{{ 'contact.form.send' | t }}</button>
      {%- endunless -%}
      {% endform %}

    </span>
  </div>
</div>
{% endif %}
<script>
  const EnquiryModal = document.querySelector(".enquiry-modal");
  const EnquiryTrigger = document.querySelector("#trigger-enquiry");
  const Enquiryclose = document.querySelector(".enquiry-modal .close-button");

  function toggleModal() {
    if (EnquiryModal) EnquiryModal.classList.toggle("show-enquiry");
  }
  function windowOnClick(event) {
    if (event.target === EnquiryModal) {
      toggleModal();
    }
  }

  if (EnquiryTrigger) EnquiryTrigger.addEventListener("click", toggleModal);
  if (Enquiryclose) Enquiryclose.addEventListener("click", toggleModal);
  window.addEventListener("click", windowOnClick);

  // Automatically show modal if enquiry form was just submitted or has errors
  if (EnquiryModal && (EnquiryModal.querySelector('.contact-form-success-banner') || EnquiryModal.querySelector('.form__message'))) {
    EnquiryModal.classList.add("show-enquiry");
  }
</script>

<style>
  .enquiry-modal {
    position: fixed;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    opacity: 0;
    display: none;
    transform: scale(1.1);
    transition: visibility 0s linear 0.25s, opacity 0.25s 0s, transform 0.25s;
  }
  .enquiry-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: white;
    padding:30px;
    width: 500px;
    max-height: 90%;
    max-width: 90%;
    overflow: auto;
    border-radius: var(--DTRadius);
      }

  .enquiry-content h4 { margin: 0 0 20px; }

  .enquiry-content .contact-form { display: grid;
    gap: 30px;
    grid-template-columns: 1fr; }

  .enquiry-content .enquiry-choose {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

    .enquiry-content .enquiry-choose input { margin-right: 5px; }
  .enquiry-content .enquiry-choose input:not(:first-child) { margin-left: 15px; }


  .enquiry-content .btn {
    margin: 0;
  }

  .enquiry-content table {
    table-layout: auto;
    margin: 0;
  }
  .enquiry-content .close-button {
    position: absolute;
    right: 10px;
    top: 10px;
  }
  .show-enquiry {
    z-index: 12;
    opacity: 1;
    display: block;
    transform: scale(1.0);
    transition: visibility 0s linear 0s, opacity 0.25s 0s, transform 0.25s;
  }
  .trigger-enquiry {
    margin: -10px 0px 5px 140px;
    display: flex;
    line-height: 1.5;
  }
  .trigger-enquiry svg{ 
    margin-right:5px;
  }

  @media only screen and (max-width: 749px) {
    .enquiry-content, .size-chart-content table { width: 100% ; }
    .size-chart-content th, .size-chart-content td { padding: 10px;}
  }
</style>