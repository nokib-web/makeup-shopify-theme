{% if section.settings.enable_overlay %}
  {% assign section_overlay = 'dt-sc-overlay' %}
{% endif %}

{% case section.settings.grid_columns %}
  {% when '3' %}
    {% assign column_class = 'dt-sc-column three-column' %}
  {% when '4' %}
    {% assign column_class = 'dt-sc-column four-column' %}
  {% when '5' %}
    {% assign column_class = 'dt-sc-column five-column' %}
  {% when '6' %}
    {% assign column_class = 'dt-sc-column six-column' %}
  {% else %}
    {% assign column_class = 'dt-sc-column six-column' %}
{% endcase %}

<div class="dt-sc-section-wrapper {{ section_overlay }}" style="background-color: {{ section.settings.background_color | default: '#ffffff' }}; {% render 'bg-color-image-padding' %}">
  <div class="{% render 'container-settings' %}">
    <div class="row {{ section.settings.custom_class_name }}">
      
      {% render 'section-heading', class: section.id %}

      <div class="category-circles-wrapper">
        <ul class="category-circles-list {{ column_class }}">
          
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {% assign collection_ref = collections[block.settings.collection] %}

              {% if block.settings.image != blank %}
                {% assign circle_img = block.settings.image | img_url: '400x400', crop: 'center' %}
              {% elsif collection_ref.image != blank %}
                {% assign circle_img = collection_ref.image | img_url: '400x400', crop: 'center' %}
              {% elsif collection_ref.products.first.featured_image != blank %}
                {% assign circle_img = collection_ref.products.first.featured_image | img_url: '400x400', crop: 'center' %}
              {% else %}
                {% assign circle_img = blank %}
              {% endif %}

              {% if block.settings.title != blank %}
                {% assign circle_title = block.settings.title %}
              {% elsif collection_ref.title != blank %}
                {% assign circle_title = collection_ref.title %}
              {% else %}
                {% assign circle_title = "Category" %}
              {% endif %}

              {% if block.settings.link != blank %}
                {% assign circle_link = block.settings.link %}
              {% elsif collection_ref.url != blank %}
                {% assign circle_link = collection_ref.url %}
              {% else %}
                {% assign circle_link = "#" %}
              {% endif %}

              <li class="category-circle-item" {{ block.shopify_attributes }}>
                <a href="{{ circle_link }}" class="category-circle-card">
                  <div class="category-circle-image-container">
                    {% if circle_img != blank %}
                      <img
                        src="{{ circle_img }}"
                        alt="{{ circle_title | escape }}"
                        loading="lazy"
                        class="category-circle-img"
                      >
                    {% else %}
                      {% capture placeholder_idx %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                      {{ 'collection-' | append: placeholder_idx | placeholder_svg_tag: 'placeholder-svg category-circle-placeholder' }}
                    {% endif %}
                  </div>
                  {% if circle_title != blank %}
                    <span class="category-circle-title">{{ circle_title }}</span>
                  {% endif %}
                </a>
              </li>
            {%- endfor -%}
          {%- else -%}
            {% comment %} Fallback default 6 categories if no blocks are added {% endcomment %}
            {% assign default_titles = "Lips Gloss,Moisturizer,Eyeliner,Serum,Cleanser,Perfume" | split: "," %}
            {% assign default_images = "https://images.unsplash.com/photo-1586495777744-4413f21062fa?auto=format&fit=crop&w=400&q=80,https://images.unsplash.com/photo-1556228720-195a672e8a03?auto=format&fit=crop&w=400&q=80,https://images.unsplash.com/photo-1512496015851-a90fb38ba796?auto=format&fit=crop&w=400&q=80,https://images.unsplash.com/photo-1620916566398-39f1143ab7be?auto=format&fit=crop&w=400&q=80,https://images.unsplash.com/photo-1556228722-d1191e4b85c1?auto=format&fit=crop&w=400&q=80,https://images.unsplash.com/photo-1541643600914-78b084683601?auto=format&fit=crop&w=400&q=80" | split: "," %}
            
            {% for def_title in default_titles %}
              <li class="category-circle-item">
                <a href="#" class="category-circle-card">
                  <div class="category-circle-image-container">
                    <img src="{{ default_images[forloop.index0] }}" alt="{{ def_title }}" loading="lazy" class="category-circle-img">
                  </div>
                  <span class="category-circle-title">{{ def_title }}</span>
                </a>
              </li>
            {% endfor %}
          {%- endif -%}

        </ul>
      </div>

    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }}.home-category-circles .dt-sc-heading .dt-sc-main-heading {
    color: {{ section.settings.section_heading_color | default: "#1A1A1A" }};
    font-size: {{ section.settings.heading_size | default: "32" }}px;
    font-family: var(--DTFontTypo_Heading), 'Cormorant Garamond', 'Playfair Display', serif;
    font-weight: 600;
    text-transform: capitalize;
  }

  .category-circles-wrapper {
    width: 100%;
    margin-top: 30px;
  }

  .category-circles-list {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: center;
    gap: 30px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .category-circle-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 0 0 calc(16.666% - 25px);
    max-width: calc(16.666% - 25px);
  }

  .category-circle-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none !important;
    width: 100%;
  }

  .category-circle-image-container {
    width: {{ section.settings.circle_size | default: "160" }}px;
    height: {{ section.settings.circle_size | default: "160" }}px;
    border-radius: 50%;
    overflow: hidden;
    position: relative;
    background-color: #f7f7f7;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.06);
    border: {{ section.settings.circle_border_width | default: "0" }}px solid {{ section.settings.circle_border_color | default: "transparent" }};
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
  }

  .category-circle-card:hover .category-circle-image-container {
    transform: scale(1.06);
    box-shadow: 0 14px 35px rgba(0, 0, 0, 0.12);
  }

  .category-circle-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .category-circle-card:hover .category-circle-img {
    transform: scale(1.08);
  }

  .category-circle-placeholder {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }

  .category-circle-title {
    font-size: {{ section.settings.caption_size | default: "15" }}px;
    font-weight: 500;
    color: {{ section.settings.caption_color | default: "#222222" }};
    margin-top: 14px;
    text-align: center;
    line-height: 1.3;
    transition: color 0.3s ease;
  }

  .category-circle-card:hover .category-circle-title {
    color: {{ section.settings.caption_hover_color | default: "#FC4C4B" }};
  }

  /* Responsive styling */
  @media (max-width: 1200px) {
    .category-circle-item {
      flex: 0 0 calc(20% - 24px);
      max-width: calc(20% - 24px);
    }
  }

  @media (max-width: 991px) {
    .category-circle-item {
      flex: 0 0 calc(33.333% - 20px);
      max-width: calc(33.333% - 20px);
    }
    .category-circle-image-container {
      width: 140px;
      height: 140px;
    }
  }

  @media (max-width: 576px) {
    .category-circle-list {
      gap: 20px 15px;
    }
    .category-circle-item {
      flex: 0 0 calc(50% - 15px);
      max-width: calc(50% - 15px);
    }
    .category-circle-image-container {
      width: 120px;
      height: 120px;
    }
    .category-circle-title {
      font-size: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Shop by Category Circles",
  "class": "index-section home-category-circles",
  "max_blocks": 12,
  "settings": [
    {
      "type": "checkbox",
      "id": "full",
      "label": "Show Full width",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "spacing_both_ends",
      "label": "Enable Right & Left Spacing (Works only on Fullwidth)",
      "default": false
    },
    {
      "type": "text",
      "id": "padding",
      "label": "Style value (Padding)",
      "default": "60,60",
      "info": "Top(px),Bottom(px)"
    },
    {
      "type": "text",
      "id": "margin",
      "label": "Style value (Margin)",
      "default": "0,0",
      "info": "Top(px),Bottom(px)"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Heading",
      "default": "Shop By Category"
    },
    {
      "type": "text",
      "id": "section_sub_heading",
      "label": "Sub Heading"
    },
    {
      "type": "text",
      "id": "heading_size",
      "label": "Heading Font Size (px)",
      "default": "32"
    },
    {
      "type": "color",
      "id": "section_heading_color",
      "label": "Heading Color",
      "default": "#1A1A1A"
    },
    {
      "type": "select",
      "id": "heading_position",
      "label": "Heading Alignment",
      "default": "text-center",
      "options": [
        {
          "value": "text-start",
          "label": "Left"
        },
        {
          "value": "text-center",
          "label": "Center"
        },
        {
          "value": "text-end",
          "label": "Right"
        }
      ]
    },
    {
      "type": "text",
      "id": "circle_size",
      "label": "Circle Image Size (px)",
      "default": "160"
    },
    {
      "type": "text",
      "id": "circle_border_width",
      "label": "Circle Border Width (px)",
      "default": "0"
    },
    {
      "type": "color",
      "id": "circle_border_color",
      "label": "Circle Border Color",
      "default": "#e5e5e5"
    },
    {
      "type": "text",
      "id": "caption_size",
      "label": "Category Label Size (px)",
      "default": "15"
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Category Label Color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "caption_hover_color",
      "label": "Category Label Hover Color",
      "default": "#fc4c4b"
    },
    {
      "type": "text",
      "id": "custom_class_name",
      "label": "Custom Class Name"
    }
  ],
  "blocks": [
    {
      "type": "category_item",
      "name": "Category Circle Item",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom Circle Image (Overrides collection image)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category Label",
          "info": "Leave empty to use Collection Title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom Link",
          "info": "Leave empty to use Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by Category Circles",
      "blocks": [
        {
          "type": "category_item",
          "settings": {
            "title": "Lips Gloss"
          }
        },
        {
          "type": "category_item",
          "settings": {
            "title": "Moisturizer"
          }
        },
        {
          "type": "category_item",
          "settings": {
            "title": "Eyeliner"
          }
        },
        {
          "type": "category_item",
          "settings": {
            "title": "Serum"
          }
        },
        {
          "type": "category_item",
          "settings": {
            "title": "Cleanser"
          }
        },
        {
          "type": "category_item",
          "settings": {
            "title": "Perfume"
          }
        }
      ]
    }
  ]
}
{% endschema %}
