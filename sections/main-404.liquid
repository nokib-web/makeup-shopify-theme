{%- liquid
  assign image = section.settings.image
  
  if section.settings.title != blank
    assign heading = section.settings.title
  else
    assign heading = 'general.404.title' | t
  endif

  if section.settings.text != blank and section.settings.text != '<p></p>'
    assign text = section.settings.text
  else
    assign text = 'general.404.subtext_html' | t
  endif

  assign button_label = section.settings.button_label
  assign button_link = section.settings.button_link | default: routes.root_url
-%}

<div class="main-404-section section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color | default: 'var(--DTBodyBGColor)' }};">
  <div class="container">
    <div class="row">
      <div class="main-404-content">
        {%- if image != blank -%}
          <div class="main-404-image">
            <img class="lazyload"
                 src="{{ image | img_url: '300x' }}"
                 data-src="{{ image | img_url: '800x' }}"
                 data-widths="[180, 360, 540, 720, 900]"
                 data-aspectratio="{{ image.aspect_ratio }}"
                 data-sizes="auto"
                 alt="{{ image.alt | escape }}">
          </div>
        {%- else -%}
          <div class="main-404-image fallback">
            <img class="lazyload" 
                 src="{{ 'makeup-404-illustration.png' | asset_url }}" 
                 alt="404 Not Found"
                 style="max-width: {{ section.settings.image_max_width }}px; height: auto;">
          </div>
        {%- endif -%}

        {%- if heading != blank -%}
          <h1 class="main-404-heading">{{ heading }}</h1>
        {%- endif -%}
        
        {%- if text != blank -%}
          <div class="main-404-text rte">
            {{ text }}
          </div>
        {%- endif -%}

        {%- if button_label != blank and button_link != blank -%}
          <div class="main-404-action">
            <a href="{{ button_link }}" class="dt-sc-btn">{{ button_label }}</a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  .main-404-section {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    width: 100%;
  }
  .main-404-content {
    max-width: 650px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
    width: 100%;
  }
  .main-404-image {
    width: 100%;
    max-width: {{ section.settings.image_max_width }}px;
    margin: 0 auto;
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
  .main-404-image:hover {
    transform: translateY(-8px);
  }
  .main-404-image img {
    width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
    border-radius: var(--DTRadius);
  }
  .main-404-heading {
    font-family: var(--DTFontTypo_Heading);
    font-size: var(--DTFontSize_H2);
    color: var(--DTColor_Heading);
    margin: 0;
    font-weight: 700;
    letter-spacing: 0.5px;
    line-height: var(--DT_Heading_Line_Height);
  }
  .main-404-text {
    font-family: var(--DTFontTypo_Body);
    font-size: calc(var(--font-size-body) + 1px);
    color: var(--DTColor_Body);
    line-height: var(--DT_Body_Line_Height);
    margin: 0;
    max-width: 500px;
  }
  .main-404-text a {
    color: var(--DTPrimaryColor);
    text-decoration: underline;
    font-weight: 600;
    transition: color var(--DTBaseTransition);
  }
  .main-404-text a:hover {
    color: var(--DTSecondaryColor);
  }
  .main-404-action {
    margin-top: 8px;
  }
  .main-404-action .dt-sc-btn {
    display: inline-block;
    padding: var(--DTPadding_Btn);
    background: var(--DT_Button_BG_Color);
    color: var(--DT_Button_Text_Color);
    border-radius: var(--DT_Button_Border_Radius);
    border: var(--DT_Button_border_width) solid var(--DT_Button_border_Color);
    font-family: var(--DTFontTypo_Body);
    font-size: var(--font-size-body);
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all var(--DTBaseTransition);
    box-shadow: var(--DTboxShadow_light);
  }
  .main-404-action .dt-sc-btn:hover {
    background: var(--DT_Button_BG_Hover_Color);
    color: var(--DT_Button_Text_Hover_Color);
    border-color: var(--DT_Button_hover_border_Color);
    transform: translateY(-3px);
    box-shadow: var(--DTboxShadow);
  }
</style>

{% schema %}
{
  "name": "404 Page Settings",
  "tag": "section",
  "class": "section-404",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "404 Custom Image"
    },
    {
      "type": "range",
      "id": "image_max_width",
      "min": 100,
      "max": 600,
      "step": 10,
      "unit": "px",
      "label": "Image Max Width",
      "default": 350
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "404 Page Not Found"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Subtext",
      "default": "<p>The page you requested does not exist. Click here to continue shopping.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Continue Shopping"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color Override",
      "info": "Leave blank to use theme's global background"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ]
}
{% endschema %}