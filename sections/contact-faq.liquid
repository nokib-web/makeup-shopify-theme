{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .contact-faq-{{ section.id }},
  .contact-faq-{{ section.id }} *,
  .contact-faq-{{ section.id }} *::before,
  .contact-faq-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  .contact-faq-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
  
  @media screen and (min-width: 990px) {
    .contact-faq-{{ section.id }} {
      flex-direction: row;
      gap: 6rem;
    }
  }

  .faq-left-{{ section.id }} {
    flex: 1;
  }

  .faq-right-{{ section.id }} {
    flex: 1.5;
  }

  .faq-badge-{{ section.id }} {
    display: inline-block;
    font-size: {{ section.settings.badge_font_size }}px;
    color: {{ section.settings.badge_color }};
    font-weight: {{ section.settings.badge_font_weight }};
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
  }

  .faq-title-{{ section.id }} {
    font-size: {{ section.settings.title_font_size_mobile }}px;
    color: {{ section.settings.title_color }};
    font-weight: {{ section.settings.title_font_weight }};
    margin: 0 0 2rem 0;
    line-height: 1.2;
  }
  @media screen and (min-width: 750px) {
    .faq-title-{{ section.id }} {
      font-size: {{ section.settings.title_font_size_desktop }}px;
    }
  }

  .faq-link-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: {{ section.settings.link_font_size }}px;
    color: {{ section.settings.link_color }};
    font-weight: {{ section.settings.link_font_weight }};
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: opacity 0.3s ease;
  }
  
  .faq-link-{{ section.id }}:hover {
    opacity: 0.7;
  }

  .faq-accordion-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item-{{ section.id }} {
    background-color: {{ section.settings.acc_bg_color }};
    border: 1px solid {{ section.settings.acc_border_color }};
    border-radius: {{ section.settings.acc_border_radius }}px;
    overflow: hidden;
  }

  .faq-question-{{ section.id }} {
    width: 100%;
    display: flex;
    flex-wrap: nowrap;
    justify-content: space-between;
    align-items: center;
    padding: {{ section.settings.acc_padding }}px;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    font-size: {{ section.settings.acc_question_size }}px;
    color: {{ section.settings.acc_question_color }};
    font-weight: {{ section.settings.acc_question_weight }};
    font-family: inherit;
    transition: background-color 0.2s ease;
    transform: none !important;
  }

  .faq-question-text-{{ section.id }} {
    flex: 1 1 auto;
    min-width: 0;
    padding-right: 16px;
  }

  .faq-question-{{ section.id }}:hover,
  .faq-question-{{ section.id }}:focus,
  .faq-question-{{ section.id }}:active {
    background-color: {{ section.settings.acc_question_hover_bg }};
    transform: none !important;
    scale: 1 !important;
  }

  .faq-item-{{ section.id }}:hover {
    transform: none !important;
    scale: 1 !important;
  }

  .faq-icon-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: {{ section.settings.acc_icon_color }};
    transition: transform 0.3s ease;
  }

  .faq-item-{{ section.id }}.active .faq-icon-{{ section.id }} {
    transform: rotate(45deg);
  }

  .faq-answer-{{ section.id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    padding: 0 {{ section.settings.acc_padding }}px;
    background-color: {{ section.settings.acc_answer_bg }};
  }

  .faq-item-{{ section.id }}.active .faq-answer-{{ section.id }} {
    padding-bottom: {{ section.settings.acc_padding }}px;
  }

  .faq-answer-content-{{ section.id }} {
    font-size: {{ section.settings.acc_answer_size }}px;
    color: {{ section.settings.acc_answer_color }};
    line-height: 1.6;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="contact-faq-{{ section.id }}">
    
    <!-- Left Area -->
    <div class="faq-left-{{ section.id }}">
      {%- if section.settings.badge_text != blank -%}
        <div class="faq-badge-{{ section.id }}">{{ section.settings.badge_text }}</div>
      {%- endif -%}
      
      {%- if section.settings.title_text != blank -%}
        <h2 class="faq-title-{{ section.id }}">{{ section.settings.title_text }}</h2>
      {%- endif -%}
      
      {%- if section.settings.link_text != blank -%}
        <a href="{{ section.settings.link_url | default: '#' }}" class="faq-link-{{ section.id }}">
          {{ section.settings.link_text }}
          <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-arrow" viewBox="0 0 14 10" width="14" height="10"><path fill-rule="evenodd" clip-rule="evenodd" d="M8.537.808a.5.5 0 01.817-.162l4 4a.5.5 0 010 .708l-4 4a.5.5 0 11-.708-.708L11.793 5.5H1a.5.5 0 010-1h10.793L8.646 1.354a.5.5 0 01-.109-.546z" fill="currentColor"></path></svg>
        </a>
      {%- endif -%}
    </div>

    <!-- Right Accordion Area -->
    <div class="faq-right-{{ section.id }}">
      <div class="faq-accordion-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="faq-item-{{ section.id }}" {{ block.shopify_attributes }}>
            <button class="faq-question-{{ section.id }}" aria-expanded="false">
              <span class="faq-question-text-{{ section.id }}">{{ block.settings.question }}</span>
              <span class="faq-icon-{{ section.id }}">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M7 1v12m-6-6h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </button>
            <div class="faq-answer-{{ section.id }}">
              <div class="faq-answer-content-{{ section.id }}">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
    
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const faqSections = document.querySelectorAll('.contact-faq-{{ section.id }}');
    
    faqSections.forEach(section => {
      const items = section.querySelectorAll('.faq-item-{{ section.id }}');
      
      items.forEach(item => {
        const questionBtn = item.querySelector('.faq-question-{{ section.id }}');
        const answerDiv = item.querySelector('.faq-answer-{{ section.id }}');
        
        questionBtn.addEventListener('click', () => {
          const isActive = item.classList.contains('active');
          
          // Close all items
          items.forEach(otherItem => {
            otherItem.classList.remove('active');
            otherItem.querySelector('.faq-answer-{{ section.id }}').style.maxHeight = null;
            otherItem.querySelector('.faq-question-{{ section.id }}').setAttribute('aria-expanded', 'false');
          });
          
          // Open clicked item if it wasn't active
          if (!isActive) {
            item.classList.add('active');
            answerDiv.style.maxHeight = answerDiv.scrollHeight + (parseInt(getComputedStyle(answerDiv).paddingBottom) || 20) + "px";
            questionBtn.setAttribute('aria-expanded', 'true');
          }
        });
      });
    });
  });
</script>

