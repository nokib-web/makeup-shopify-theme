{% comment %}
  Custom Multi-Tab Collection Showcase Section for Beauty & Cosmetics
  Fully integrated with Theme Design System, Heading Brush & Background Image Support
{% endcomment %}

{%- assign section_bg_color = section.settings.section_bg_color -%}
{%- assign section_bg_image = section.settings.section_bg_image -%}

<div class="dt-sc-section-wrapper custom-tabbed-collection-section" id="custom-tabbed-{{ section.id }}">
  <div class="{% render 'container-settings' %}">
    
    {% comment %} Native Theme Section Header (with Brush & Typography) {% endcomment %}
    <div class="row {{ section.settings.custom_class_name }}">
      {% render 'section-heading', class: section.id %}
    </div>

    {% comment %} Tab Navigation Buttons {% endcomment %}
    {%- if section.blocks.size > 0 -%}
      <div class="custom-tab-nav-wrapper">
        <div class="custom-tab-nav">
          {%- for block in section.blocks -%}
            <button 
              type="button" 
              class="custom-tab-btn {% if forloop.first %}active{% endif %}" 
              data-tab-target="#custom-tab-panel-{{ block.id }}"
              {{ block.shopify_attributes }}
            >
              <span>{{ block.settings.title | default: block.settings.collection.title | default: "Collection Tab" }}</span>
            </button>
          {%- endfor -%}
        </div>
      </div>

      {% comment %} Tab Panels {% endcomment %}
      <div class="custom-tab-panels">
        {%- for block in section.blocks -%}
          {%- assign featured_collection = collections[block.settings.collection] -%}
          {%- assign limit = section.settings.products_to_show | default: 4 -%}
          
          <div 
            class="custom-tab-panel {% if forloop.first %}active{% endif %}" 
            id="custom-tab-panel-{{ block.id }}"
          >
            <div class="custom-product-grid columns-{{ section.settings.columns }}">
              {%- if featured_collection != blank and featured_collection.products_count > 0 -%}
                {%- for product in featured_collection.products limit: limit -%}
                  <div class="custom-product-grid-item">
                    {%- render 'product-grid-item', product: product, section: section -%}
                  </div>
                {%- endfor -%}
              {%- else -%}
                {% comment %} Onboarding Dummy Products if Collection is empty {% endcomment %}
                {%- for i in (1..limit) -%}
                  <div class="custom-product-grid-item onboarding-item">
                    <div class="bestseller-product-card">
                      <div class="bestseller-image-wrapper ratio-1-1" style="background: #f4f4f4; display: flex; align-items: center; justify-content: center;">
                        {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                        {{ 'product-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                      <div class="bestseller-card-info" style="padding: 15px; text-align: center; display: flex; flex-direction: column; justify-content: space-between; flex-grow: 1;">
                        <h3 class="bestseller-product-title">Sample Beauty Product {{ i }}</h3>
                        <div class="bestseller-card-price" style="font-weight: 600; margin-top: 5px;">$29.00</div>
                        <button class="dt-sc-btn" style="width: 100%; margin-top: 10px;">Add to Bag</button>
                      </div>
                    </div>
                  </div>
                {%- endfor -%}
              {%- endif -%}
            </div>
            
            {%- if block.settings.show_view_all and featured_collection != blank -%}
              <div class="custom-tab-view-all" style="text-align: center; margin-top: 40px;">
                <a href="{{ featured_collection.url }}" class="dt-sc-btn custom-view-all-btn">
                  {{ block.settings.view_all_label | default: 'View All Collection' }}
                </a>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

<style>
  #custom-tabbed-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section_bg_color }};
    {% if section_bg_image != blank %}
      background-image: url('{{ section_bg_image | img_url: '2000x' }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
  }

  .custom-tabbed-collection-section {
    width: 100%;
    overflow: hidden;
  }

  /* Minimalist Editorial Tab Bar Navigation (Rhode / Glossier Style) */
  .custom-tab-nav-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 40px;
  }

  .custom-tab-nav {
    display: inline-flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .custom-tab-btn {
    background-color: transparent !important;
    color: var(--DT_Button_BG_Color, var(--DTPrimaryColor, #e63946)) !important;
    border: 1px solid var(--DT_Button_BG_Color, var(--DTPrimaryColor, #e63946)) !important;
    border-radius: var(--DT_Button_Border_Radius, 4px) !important;
    padding: 10px 24px;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .custom-tab-btn:hover {
    background-color: var(--DT_Button_BG_Color, var(--DTPrimaryColor, #e63946)) !important;
    color: var(--DT_Button_Text_Color, #ffffff) !important;
    border-color: var(--DT_Button_border_Color, var(--DTPrimaryColor, #e63946)) !important;
  }

  .custom-tab-btn.active {
    background-color: var(--DT_Button_BG_Color, var(--DTPrimaryColor, #e63946)) !important;
    color: var(--DT_Button_Text_Color, #ffffff) !important;
    border-color: var(--DT_Button_border_Color, var(--DTPrimaryColor, #e63946)) !important;
    box-shadow: 0 4px 14px rgba(0,0,0,0.12);
  }

  .custom-tab-panel {
    display: none;
    opacity: 0;
    transition: opacity 0.4s ease-in-out;
  }

  .custom-tab-panel.active {
    display: block;
    opacity: 1;
  }

  /* Equal Height Product Grid */
  .custom-product-grid {
    display: grid;
    gap: 24px;
    align-items: stretch;
  }

  .custom-product-grid.columns-2 { grid-template-columns: repeat(2, 1fr); }
  .custom-product-grid.columns-3 { grid-template-columns: repeat(3, 1fr); }
  .custom-product-grid.columns-4 { grid-template-columns: repeat(4, 1fr); }

  .custom-product-grid-item,
  .custom-product-grid-item > li,
  .custom-product-grid-item .products,
  .custom-product-grid-item .product-detail,
  .custom-product-grid-item .bestseller-product-card {
    display: flex !important;
    flex-direction: column !important;
    height: 100% !important;
    flex: 1 1 auto !important;
  }

  /* Minimalist Editorial Card Styling */
  .custom-product-grid-item .bestseller-product-card {
    border: 1px solid #EAEAEA !important;
    border-radius: 4px !important;
    background: #FFFFFF !important;
    box-shadow: none !important;
    transition: all 0.3s ease !important;
    overflow: hidden;
  }

  .custom-product-grid-item .bestseller-product-card:hover {
    transform: translateY(-4px) !important;
    border-color: #111111 !important;
    box-shadow: 0 10px 25px rgba(0,0,0,0.06) !important;
  }

  .custom-product-grid-item .bestseller-card-info {
    display: flex !important;
    flex-direction: column !important;
    flex-grow: 1 !important;
    justify-content: space-between !important;
    padding: 16px !important;
  }

  .custom-product-grid-item .bestseller-action-form {
    margin-top: auto !important;
  }

  /* View All Button - Uses Global Theme Button Variables */
  .custom-tab-view-all a.custom-view-all-btn {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    background-color: var(--DT_Button_BG_Color, var(--DTPrimaryColor, #e63946)) !important;
    color: var(--DT_Button_Text_Color, #ffffff) !important;
    border: var(--DT_Button_border_width, 1px) solid var(--DT_Button_border_Color, var(--DTPrimaryColor, #e63946)) !important;
    border-radius: var(--DT_Button_Border_Radius, 4px) !important;
    width: auto !important;
    min-width: 220px !important;
    max-width: 100%;
    padding: 14px 38px !important;
    font-size: 13px !important;
    font-weight: 600 !important;
    letter-spacing: 0.1em !important;
    text-transform: uppercase !important;
    text-align: center;
    margin: 0 auto;
    transition: all 0.3s ease !important;
  }

  .custom-tab-view-all a.custom-view-all-btn:hover {
    background-color: var(--DT_Button_BG_Hover_Color, #333333) !important;
    color: var(--DT_Button_Text_Hover_Color, #ffffff) !important;
    border-color: var(--DT_Button_hover_border_Color, #333333) !important;
    transform: translateY(-2px) !important;
  }

  @media (max-width: 991px) {
    .custom-product-grid.columns-4 { grid-template-columns: repeat(2, 1fr); }
    .custom-product-grid.columns-3 { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 575px) {
    .custom-product-grid.columns-4,
    .custom-product-grid.columns-3,
    .custom-product-grid.columns-2 { grid-template-columns: repeat(1, 1fr); }
    .custom-tab-btn { padding: 8px 12px; font-size: 13px; }
  }
</style>

<script>
  (function() {
    var initTabbedCollection = function() {
      var section = document.getElementById('custom-tabbed-{{ section.id }}');
      if (!section) return;

      var tabButtons = section.querySelectorAll('.custom-tab-btn');
      var tabPanels = section.querySelectorAll('.custom-tab-panel');

      tabButtons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          var targetId = btn.getAttribute('data-tab-target');
          
          tabButtons.forEach(function(b) { b.classList.remove('active'); });
          tabPanels.forEach(function(p) { p.classList.remove('active'); });

          btn.classList.add('active');
          var targetPanel = section.querySelector(targetId);
          if (targetPanel) {
            targetPanel.classList.add('active');
          }
        });
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTabbedCollection);
    } else {
      initTabbedCollection();
    }
  })();
</script>

{% schema %}
{
  "name": "Multi-Tab Showcase",
  "class": "index-section",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Heading",
      "default": "Shop By Category"
    },
    {
      "type": "text",
      "id": "section_sub_heading",
      "label": "Sub Heading",
      "default": "EXPLORE POPULAR CATEGORIES"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_position",
      "label": "Heading Alignment",
      "default": "text-center",
      "options": [
        { "value": "text-left", "label": "Left" },
        { "value": "text-center", "label": "Center" },
        { "value": "text-right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products per Tab",
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns Count",
      "default": 4
    },
    {
      "type": "header",
      "content": "Section Style & Background"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "section_bg_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "collection_tab",
      "name": "Collection Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab Title Override",
          "info": "Leave blank to use collection title"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "checkbox",
          "id": "show_view_all",
          "label": "Show 'View All' Button",
          "default": true
        },
        {
          "type": "text",
          "id": "view_all_label",
          "label": "'View All' Button Text",
          "default": "View All Products"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multi-Tab Showcase",
      "category": "Collection",
      "blocks": [
        {
          "type": "collection_tab",
          "settings": {
            "title": "Best Sellers"
          }
        },
        {
          "type": "collection_tab",
          "settings": {
            "title": "Lip & Gloss"
          }
        },
        {
          "type": "collection_tab",
          "settings": {
            "title": "Skin Care"
          }
        }
      ]
    }
  ]
}
{% endschema %}
