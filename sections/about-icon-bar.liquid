<div class="icon-bar-section">
  <div class="icon-bar">
    <div class="icon-bar__grid">

      {%- for block in section.blocks -%}
        {%- if block.type == 'icon_item' -%}
          <div class="icon-bar__item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon -%}
              <div class="icon-bar__icon-wrap">
                <img
                  class="icon-bar__icon"
                  src="{{ block.settings.icon | image_url: width: 200 }}"
                  alt="{{ block.settings.icon.alt | default: block.settings.title | escape }}"
                  width="{{ block.settings.icon.width }}"
                  height="{{ block.settings.icon.height }}"
                  loading="lazy"
                >
              </div>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <p class="icon-bar__title">{{ block.settings.title }}</p>
            {%- endif -%}

            {%- if block.settings.description != blank -%}
              <div class="icon-bar__description">{{ block.settings.description }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    --icon-bar-padding-top: {{ section.settings.padding_top }}px;
    --icon-bar-padding-bottom: {{ section.settings.padding_bottom }}px;
    --icon-bar-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --icon-bar-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --icon-bar-padding-horizontal: {{ section.settings.padding_horizontal }}px;
    --icon-bar-max-width: {{ section.settings.max_width }}px;
    --icon-bar-bg-color: {{ section.settings.bg_color }};
    --icon-bar-divider-color: {{ section.settings.divider_color }};

    background-color: var(--icon-bar-bg-color);
  }

  #shopify-section-{{ section.id }} .icon-bar {
    max-width: var(--icon-bar-max-width);
    margin: 0 auto;
    padding: var(--icon-bar-padding-top) var(--icon-bar-padding-horizontal) var(--icon-bar-padding-bottom);
  }

  #shopify-section-{{ section.id }} .icon-bar__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .icon-bar__item {
    flex: 1 1 200px;
    max-width: 280px;
    text-align: center;
    padding: 0 32px;
    border-right: 1px solid var(--icon-bar-divider-color);
  }

  #shopify-section-{{ section.id }} .icon-bar__item:last-child {
    border-right: none;
  }

  #shopify-section-{{ section.id }} .icon-bar__icon-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
  }

  #shopify-section-{{ section.id }} .icon-bar__icon {
    width: {{ section.settings.icon_width }}px;
    height: {{ section.settings.icon_height }}px;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .icon-bar__title {
    font-size: var(--icon-bar-title-size-mobile);
    color: var(--icon-bar-title-color);
    font-weight: var(--icon-bar-title-weight);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 12px;
  }

  #shopify-section-{{ section.id }} .icon-bar__description {
    font-size: var(--icon-bar-desc-size);
    color: var(--icon-bar-desc-color);
    font-weight: var(--icon-bar-desc-weight);
    max-width: var(--icon-bar-desc-max-width);
    line-height: 1.6;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .icon-bar__description p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} {
    --icon-bar-title-size: {{ section.settings.title_font_size }}px;
    --icon-bar-title-size-mobile: {{ section.settings.title_font_size_mobile }}px;
    --icon-bar-title-color: {{ section.settings.title_color }};
    --icon-bar-title-weight: {{ section.settings.title_font_weight }};

    --icon-bar-desc-size: {{ section.settings.description_font_size }}px;
    --icon-bar-desc-color: {{ section.settings.description_color }};
    --icon-bar-desc-weight: {{ section.settings.description_font_weight }};
    --icon-bar-desc-max-width: {{ section.settings.description_max_width }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .icon-bar__title {
      font-size: var(--icon-bar-title-size);
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .icon-bar {
      padding: var(--icon-bar-padding-top-mobile) var(--icon-bar-padding-horizontal) var(--icon-bar-padding-bottom-mobile);
    }

    #shopify-section-{{ section.id }} .icon-bar__grid {
      flex-direction: column;
      align-items: center;
      gap: 32px;
    }

    #shopify-section-{{ section.id }} .icon-bar__item {
      max-width: 320px;
      padding: 0 16px;
      border-right: none;
    }

    #shopify-section-{{ section.id }} .icon-bar__icon {
      width: {{ section.settings.icon_width_mobile }}px;
      height: {{ section.settings.icon_height_mobile }}px;
    }
  }
</style>

