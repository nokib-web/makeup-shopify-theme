    {
      "type": "color",
      "id": "item_color",
      "label": "Text color",
      "default": "#3A3A3A"
    },
    {
      "type": "select",
      "id": "item_font_weight",
      "label": "Text font weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" }
      ],
      "default": "400"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet Point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Premium Ingredients"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        { "type": "bullet", "settings": { "text": "Premium Ingredients" } },
        { "type": "bullet", "settings": { "text": "Skin-Loving Formulas" } },
        { "type": "bullet", "settings": { "text": "Modern Minimal Packaging" } },
        { "type": "bullet", "settings": { "text": "Tested for Performance" } },
        { "type": "bullet", "settings": { "text": "Trusted by Beauty Lovers" } }
