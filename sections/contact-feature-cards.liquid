{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .contact-features-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  
  @media screen and (min-width: 750px) {
    .contact-features-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media screen and (min-width: 990px) {
    .contact-features-{{ section.id }} {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .feature-card-{{ section.id }} {
    background-color: {{ section.settings.card_bg_color }};
    padding: {{ section.settings.card_padding }}px;
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .feature-icon-{{ section.id }} {
    margin-bottom: 1.5rem;
  }

  .feature-icon-{{ section.id }} svg, .feature-icon-{{ section.id }} img {
    height: {{ section.settings.icon_height }}px;
    width: {{ section.settings.icon_width }}px;
    object-fit: contain;
  }

  .feature-title-{{ section.id }} {
    font-size: {{ section.settings.card_title_font_size }}px;
    color: {{ section.settings.card_title_color }};
    font-weight: {{ section.settings.card_title_font_weight }};
    margin: 0 0 0.5rem 0;
    line-height: 1.3;
  }

  .feature-subtitle-{{ section.id }} {
    font-size: {{ section.settings.card_subtitle_font_size }}px;
    color: {{ section.settings.card_subtitle_color }};
    font-weight: {{ section.settings.card_subtitle_font_weight }};
    margin: 0;
    line-height: 1.5;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="contact-features-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="feature-card-{{ section.id }}" {{ block.shopify_attributes }}>
        <div class="feature-icon-{{ section.id }}">
          {%- if block.settings.icon_image != blank -%}
            {{ block.settings.icon_image | image_url: width: section.settings.icon_width | image_tag: loading: 'lazy' }}
          {%- elsif block.settings.icon_svg != blank -%}
            {{ block.settings.icon_svg }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        {%- if block.settings.title != blank -%}
          <h3 class="feature-title-{{ section.id }}">{{ block.settings.title }}</h3>
        {%- endif -%}
        {%- if block.settings.subtitle != blank -%}
          <p class="feature-subtitle-{{ section.id }}">{{ block.settings.subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Contact Feature Cards",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1200
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Card Styling"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Card Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Border Radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Icon Sizing"
    },
    {
      "type": "range",
      "id": "icon_width",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Icon Width",
      "default": 40
    },
    {
      "type": "range",
      "id": "icon_height",
      "min": 20,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Icon Height",
      "default": 40
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "card_title_font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Title Font Size",
      "default": 16
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Title Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "card_title_font_weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "label": "Title Font Weight",
      "default": 600
    },
    {
      "type": "range",
      "id": "card_subtitle_font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Subtitle Font Size",
      "default": 14
    },
    {
      "type": "color",
      "id": "card_subtitle_color",
      "label": "Subtitle Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "card_subtitle_font_weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "label": "Subtitle Font Weight",
      "default": 400
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG (optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Feature description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact Feature Cards",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "FAST RESPONSE",
            "subtitle": "We reply within 24 hours"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "CUSTOMER SUPPORT",
            "subtitle": "Here to help, always"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "EMAIL SUPPORT",
            "subtitle": "support@sheena.com"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "OFFICE HOURS",
            "subtitle": "Mon - Fri: 9AM - 6PM"
          }
        }
      ]
    }
  ]
}
{% endschema %}
