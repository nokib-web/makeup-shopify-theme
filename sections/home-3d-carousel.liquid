<div class="home-3d-carousel-wrapper" style="{% if section.settings.bg_image != blank %}background-image: url('{{ section.settings.bg_image | img_url: 'master' }}');{% endif %} background-color: {{ section.settings.bg_color }}; background-size: cover; background-position: center; position: relative;">
  <div class="carousel-dotted-path">
    <!-- SVG curved dotted line -->
    <svg viewBox="0 0 1000 300" preserveAspectRatio="none" style="width: 100%; height: 100%;">
      <path d="M-100,150 C250,0 750,300 1100,150" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="3" stroke-dasharray="10,15" />
    </svg>
  </div>
  <div class="container">
    <div class="swiper-container carousel-3d-{{ section.id }}">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide slide-item-3d">
            <div class="slide-content-wrap">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | img_url: '800x' }}" alt="{{ block.settings.title }}" class="slide-image">
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg slide-image' }}
              {% endif %}
              
              {% if block.settings.title != blank %}
                <div class="slide-text-overlay">
                  <h4 style="color: {{ block.settings.text_color }}">{{ block.settings.title }}</h4>
                  {% if block.settings.subtitle != blank %}
                    <p style="color: {{ block.settings.text_color }}; border-color: {{ block.settings.text_color }}">{{ block.settings.subtitle }}</p>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
      
      {% if section.settings.show_navigation %}
      <div class="swiper-button-next" style="color: {{ section.settings.nav_color }};"></div>
      <div class="swiper-button-prev" style="color: {{ section.settings.nav_color }};"></div>
      {% endif %}
      
      {% if section.settings.show_pagination %}
      <div class="swiper-pagination"></div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .home-3d-carousel-wrapper {
    padding: 100px 0;
    overflow: hidden;
  }
  .carousel-dotted-path {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    transform: translateY(-50%);
    z-index: 1;
    height: 300px;
    pointer-events: none;
  }
  .carousel-3d-{{ section.id }} {
    width: 100%;
    padding-top: 50px;
    padding-bottom: 50px;
    z-index: 2;
    overflow: visible !important;
  }
  .carousel-3d-{{ section.id }} .swiper-slide {
    background-position: center;
    background-size: cover;
    width: 500px;
    height: 600px;
  }
  
  @media (max-width: 991px) {
    .carousel-3d-{{ section.id }} .swiper-slide {
      width: 350px;
      height: 450px;
    }
  }

  @media (max-width: 575px) {
    .carousel-3d-{{ section.id }} .swiper-slide {
      width: 280px;
      height: 380px;
    }
  }

  .slide-item-3d .slide-content-wrap {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 15px 50px rgba(0,0,0,0.3);
    padding: 12px;
    background: transparent;
  }

  /* The dashed border inner wrapper */
  .slide-item-3d .slide-content-wrap::before {
    content: '';
    position: absolute;
    top: 15px;
    left: 15px;
    right: 15px;
    bottom: 15px;
    border: 2px dashed rgba(255, 255, 255, 0.7);
    border-radius: 10px;
    z-index: 5;
    pointer-events: none;
  }
  
  .slide-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 10px;
  }
  
  .slide-text-overlay {
    position: absolute;
    top: 40px;
    left: 40px;
    z-index: 10;
    text-shadow: 2px 2px 6px rgba(0,0,0,0.6);
  }
  
  .slide-text-overlay h4 {
    margin: 0;
    font-size: 38px;
    font-family: serif;
    letter-spacing: 2px;
  }
  
  .slide-text-overlay p {
    margin: 5px 0 0;
    font-size: 14px;
    border: 1px dashed;
    display: inline-block;
    padding: 4px 10px;
    border-radius: 4px;
  }
  
  {% if section.settings.show_pagination %}
  .carousel-3d-{{ section.id }} .swiper-pagination-bullet {
    background: {{ section.settings.nav_color }};
  }
  {% endif %}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if(typeof Swiper !== 'undefined') {
      var swiper3D = new Swiper('.carousel-3d-{{ section.id }}', {
        effect: 'coverflow',
        grabCursor: true,
        centeredSlides: true,
        slidesPerView: 'auto',
        loop: true,
        coverflowEffect: {
          rotate: 10,
          stretch: 50,
          depth: 300,
          modifier: 1.2,
          slideShadows: true,
        },
        {% if section.settings.autoplay %}
        autoplay: {
          delay: 3000,
          disableOnInteraction: false,
        },
        {% endif %}
        {% if section.settings.show_navigation %}
        navigation: {
          nextEl: '.swiper-button-next',
          prevEl: '.swiper-button-prev',
        },
        {% endif %}
        {% if section.settings.show_pagination %}
        pagination: {
          el: '.swiper-pagination',
          clickable: true,
        },
        {% endif %}
      });
    }
  });
</script>

{% schema %}
{
  "name": "3D Carousel",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "nav_color",
      "label": "Navigation Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show Navigation Arrows",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show Pagination Dots",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Flow"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "01 - 05"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "3D Carousel",
      "category": "Image"
    }
  ]
}
{% endschema %}
