<div class="testimonials-section">
  <div class="testimonials">
    <div class="testimonials__header">
      {%- if section.settings.eyebrow_text != blank -%}
        <p class="testimonials__eyebrow">{{ section.settings.eyebrow_text }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="testimonials__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="testimonials__carousel-wrap">
        <div class="testimonials__track" id="testimonials-track-{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- if block.type == 'review' -%}
              <div class="testimonials__card" {{ block.shopify_attributes }}>
                {%- if block.settings.rating > 0 -%}
                  <div class="testimonials__stars" aria-hidden="true">
                    {%- for i in (1..5) -%}
                      {%- if i <= block.settings.rating -%}
                        <svg viewBox="0 0 24 24" class="testimonials__star testimonials__star--filled"><path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      {%- else -%}
                        <svg viewBox="0 0 24 24" class="testimonials__star testimonials__star--empty"><path fill="currentColor" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                {%- if block.settings.review_text != blank -%}
                  <div class="testimonials__text">{{ block.settings.review_text }}</div>
                {%- endif -%}

                {%- if block.settings.customer_name != blank -%}
                  <p class="testimonials__name">— {{ block.settings.customer_name }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <button type="button" class="testimonials__nav testimonials__nav--prev" aria-label="Previous" data-direction="-1">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="{{ section.settings.title_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button type="button" class="testimonials__nav testimonials__nav--next" aria-label="Next" data-direction="1">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="{{ section.settings.title_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    --test-padding-top: {{ section.settings.padding_top }}px;
    --test-padding-bottom: {{ section.settings.padding_bottom }}px;
    --test-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --test-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --test-padding-horizontal: {{ section.settings.padding_horizontal }}px;
    --test-max-width: {{ section.settings.max_width }}px;
    --test-bg-color: {{ section.settings.bg_color }};

    --test-eyebrow-size: {{ section.settings.eyebrow_font_size }}px;
    --test-eyebrow-color: {{ section.settings.eyebrow_color }};
    --test-eyebrow-weight: {{ section.settings.eyebrow_font_weight }};

    --test-title-size: {{ section.settings.title_font_size }}px;
    --test-title-size-mobile: {{ section.settings.title_font_size_mobile }}px;
    --test-title-color: {{ section.settings.title_color }};
    --test-title-weight: {{ section.settings.title_font_weight }};

    --test-card-bg: {{ section.settings.card_bg }};
    --test-card-radius: {{ section.settings.card_radius }}px;
    --test-star-color: {{ section.settings.star_color }};
    --test-text-color: {{ section.settings.review_text_color }};
    --test-name-color: {{ section.settings.name_color }};

    background-color: var(--test-bg-color);
  }

  #shopify-section-{{ section.id }} .testimonials {
    max-width: var(--test-max-width);
    margin: 0 auto;
    padding: var(--test-padding-top) var(--test-padding-horizontal) var(--test-padding-bottom);
  }

  #shopify-section-{{ section.id }} .testimonials__header {
    text-align: center;
    margin-bottom: 40px;
  }

  #shopify-section-{{ section.id }} .testimonials__eyebrow {
    font-size: var(--test-eyebrow-size);
    color: var(--test-eyebrow-color);
    font-weight: var(--test-eyebrow-weight);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0 0 12px;
  }

  #shopify-section-{{ section.id }} .testimonials__title {
    font-size: var(--test-title-size-mobile);
    color: var(--test-title-color);
    font-weight: var(--test-title-weight);
    line-height: 1.2;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .testimonials__carousel-wrap {
    position: relative;
  }

  #shopify-section-{{ section.id }} .testimonials__track {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 4px;
    scrollbar-width: none;
  }

  #shopify-section-{{ section.id }} .testimonials__track::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .testimonials__card {
    scroll-snap-align: start;
    flex: 0 0 calc((100% - 48px) / 3);
    background-color: var(--test-card-bg);
    border-radius: var(--test-card-radius);
    padding: 32px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .testimonials__stars {
    display: flex;
    justify-content: center;
    gap: 4px;
    margin-bottom: 16px;
  }

  #shopify-section-{{ section.id }} .testimonials__star {
    width: 16px;
    height: 16px;
  }

  #shopify-section-{{ section.id }} .testimonials__star--filled {
    color: var(--test-star-color);
  }

  #shopify-section-{{ section.id }} .testimonials__star--empty {
    color: var(--test-star-color);
    opacity: 0.25;
  }

  #shopify-section-{{ section.id }} .testimonials__text {
    font-size: 15px;
    color: var(--test-text-color);
    line-height: 1.6;
    margin: 0 0 18px;
  }

  #shopify-section-{{ section.id }} .testimonials__text p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .testimonials__name {
    font-size: 14px;
    color: var(--test-name-color);
    margin: 0;
  }

  #shopify-section-{{ section.id }} .testimonials__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 50%;
    border: 1px solid var(--test-card-bg);
    background-color: var(--test-bg-color);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: 0;
    z-index: 2;
  }

  #shopify-section-{{ section.id }} .testimonials__nav svg {
    display: block;
    width: 18px;
    height: 18px;
  }

  #shopify-section-{{ section.id }} .testimonials__nav--prev {
    left: -20px;
  }

  #shopify-section-{{ section.id }} .testimonials__nav--next {
    right: -20px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .testimonials__title {
      font-size: var(--test-title-size);
    }
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .testimonials__card {
      flex: 0 0 calc((100% - 24px) / 2);
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .testimonials {
      padding: var(--test-padding-top-mobile) var(--test-padding-horizontal) var(--test-padding-bottom-mobile);
    }

    #shopify-section-{{ section.id }} .testimonials__card {
      flex: 0 0 85%;
    }

    #shopify-section-{{ section.id }} .testimonials__nav {
      display: none;
    }
  }
</style>

<script>
  (function () {
    var track = document.getElementById('testimonials-track-{{ section.id }}');
    if (!track) return;
    var wrap = track.closest('.testimonials__carousel-wrap');
    var buttons = wrap.querySelectorAll('.testimonials__nav');
    buttons.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var card = track.querySelector('.testimonials__card');
        var scrollAmount = card ? card.getBoundingClientRect().width + 24 : 300;
        track.scrollBy({
          left: scrollAmount * parseInt(btn.getAttribute('data-direction'), 10),
          behavior: 'smooth'
        });
      });
    });
  })();
</script>

