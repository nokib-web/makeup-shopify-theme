<div class="founder-section">
  <div class="founder">
    <div class="founder__grid">

      {%- if section.settings.image -%}
        <div class="founder__media">
          <img
            class="founder__image"
            src="{{ section.settings.image | image_url: width: 1400 }}"
            srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                    {{ section.settings.image | image_url: width: 1000 }} 1000w,
                    {{ section.settings.image | image_url: width: 1400 }} 1400w"
            sizes="(min-width: 990px) 50vw, 100vw"
            alt="{{ section.settings.image.alt | default: section.settings.name | escape }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}

      <div class="founder__content">
        {%- if section.settings.eyebrow_text != blank -%}
          <p class="founder__eyebrow">{{ section.settings.eyebrow_text }}</p>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="founder__title">{{ section.settings.title }}</h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="founder__description">{{ section.settings.description }}</div>
        {%- endif -%}

        {%- if section.settings.signature -%}
          <img
            class="founder__signature"
            src="{{ section.settings.signature | image_url: width: 400 }}"
            alt="{{ section.settings.name | escape }}"
            width="{{ section.settings.signature.width }}"
            height="{{ section.settings.signature.height }}"
            loading="lazy"
          >
        {%- endif -%}

        {%- if section.settings.name != blank -%}
          <p class="founder__name">{{ section.settings.name }}</p>
        {%- endif -%}

        {%- if section.settings.position != blank -%}
          <p class="founder__position">{{ section.settings.position }}</p>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    --founder-padding-top: {{ section.settings.padding_top }}px;
    --founder-padding-bottom: {{ section.settings.padding_bottom }}px;
    --founder-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --founder-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --founder-padding-horizontal: {{ section.settings.padding_horizontal }}px;
    --founder-max-width: {{ section.settings.max_width }}px;
    --founder-bg-color: {{ section.settings.bg_color }};

    --founder-image-height: {{ section.settings.image_height }}px;
    --founder-image-width: {{ section.settings.image_width }}%;
    --founder-image-radius: {{ section.settings.image_radius }}px;

    --founder-eyebrow-size: {{ section.settings.eyebrow_font_size }}px;
    --founder-eyebrow-color: {{ section.settings.eyebrow_color }};
    --founder-eyebrow-weight: {{ section.settings.eyebrow_font_weight }};

    --founder-title-size: {{ section.settings.title_font_size }}px;
    --founder-title-size-mobile: {{ section.settings.title_font_size_mobile }}px;
    --founder-title-color: {{ section.settings.title_color }};
    --founder-title-weight: {{ section.settings.title_font_weight }};

    --founder-desc-size: {{ section.settings.description_font_size }}px;
    --founder-desc-color: {{ section.settings.description_color }};
    --founder-desc-weight: {{ section.settings.description_font_weight }};
    --founder-desc-max-width: {{ section.settings.description_max_width }}px;

    --founder-signature-width: {{ section.settings.signature_width }}px;
    --founder-signature-height: {{ section.settings.signature_height }}px;

    --founder-name-size: {{ section.settings.name_font_size }}px;
    --founder-name-color: {{ section.settings.name_color }};
    --founder-name-weight: {{ section.settings.name_font_weight }};

    --founder-position-size: {{ section.settings.position_font_size }}px;
    --founder-position-color: {{ section.settings.position_color }};
    --founder-position-weight: {{ section.settings.position_font_weight }};

    background-color: var(--founder-bg-color);
  }

  #shopify-section-{{ section.id }} .founder {
    max-width: var(--founder-max-width);
    margin: 0 auto;
    padding: var(--founder-padding-top) var(--founder-padding-horizontal) var(--founder-padding-bottom);
  }

  #shopify-section-{{ section.id }} .founder__grid {
    display: flex;
    align-items: center;
    gap: 60px;
  }

  #shopify-section-{{ section.id }} .founder__media {
    order: 1;
    flex: 0 0 var(--founder-image-width);
    max-width: var(--founder-image-width);
    margin-left: calc(-1 * var(--founder-padding-horizontal));
  }

  #shopify-section-{{ section.id }} .founder__image {
    display: block;
    width: 100%;
    height: var(--founder-image-height);
    object-fit: cover;
    border-radius: var(--founder-image-radius);
    {%- if section.settings.enable_shadow -%}
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.18);
    {%- endif -%}
  }

  #shopify-section-{{ section.id }} .founder__content {
    order: 2;
    flex: 1 1 0%;
    min-width: 280px;
  }

  #shopify-section-{{ section.id }} .founder__eyebrow {
    font-size: var(--founder-eyebrow-size);
    color: var(--founder-eyebrow-color);
    font-weight: var(--founder-eyebrow-weight);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 16px;
  }

  #shopify-section-{{ section.id }} .founder__title {
    font-size: var(--founder-title-size-mobile);
    color: var(--founder-title-color);
    font-weight: var(--founder-title-weight);
    line-height: 1.2;
    margin: 0 0 20px;
  }

  #shopify-section-{{ section.id }} .founder__description {
    font-size: var(--founder-desc-size);
    color: var(--founder-desc-color);
    font-weight: var(--founder-desc-weight);
    max-width: var(--founder-desc-max-width);
    line-height: 1.7;
    margin: 0 0 28px;
  }

  #shopify-section-{{ section.id }} .founder__description p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .founder__signature {
    display: block;
    width: var(--founder-signature-width);
    height: var(--founder-signature-height);
    object-fit: contain;
    margin: 0 0 12px;
  }

  #shopify-section-{{ section.id }} .founder__name {
    font-size: var(--founder-name-size);
    color: var(--founder-name-color);
    font-weight: var(--founder-name-weight);
    margin: 0 0 4px;
  }

  #shopify-section-{{ section.id }} .founder__position {
    font-size: var(--founder-position-size);
    color: var(--founder-position-color);
    font-weight: var(--founder-position-weight);
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .founder__title {
      font-size: var(--founder-title-size);
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .founder {
      padding: var(--founder-padding-top-mobile) var(--founder-padding-horizontal) var(--founder-padding-bottom-mobile);
    }

    #shopify-section-{{ section.id }} .founder__grid {
      flex-direction: column;
      gap: 32px;
    }

    #shopify-section-{{ section.id }} .founder__media {
      flex: 1 1 auto;
      max-width: none;
      width: 100%;
      margin-left: calc(-1 * var(--founder-padding-horizontal));
      margin-right: calc(-1 * var(--founder-padding-horizontal));
    }

    #shopify-section-{{ section.id }} .founder__image {
      height: 340px;
      border-radius: 0;
    }

    #shopify-section-{{ section.id }} .founder__content {
      min-width: 0;
    }
  }
</style>

