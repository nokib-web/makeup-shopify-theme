{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer="defer"></script>

<div class="hero2-section">
  <div class="hero2">
    <div class="hero2__grid">

      <div class="hero2__content">
        {%- if section.settings.eyebrow_text != blank -%}
          <p class="hero2__eyebrow">{{ section.settings.eyebrow_text }}</p>
        {%- endif -%}

        <h1 class="hero2__title">
          {%- if section.settings.title_line1 != blank -%}
            <span class="hero2__title-line1">{{ section.settings.title_line1 }}</span><br>
          {%- endif -%}
          {%- if section.settings.title_highlight != blank -%}
            <span class="hero2__title-highlight">{{ section.settings.title_highlight }}</span>
          {%- endif -%}
          {%- if section.settings.title_line2 != blank -%}
            <span class="hero2__title-line2">{{ section.settings.title_line2 }}</span>
          {%- endif -%}
        </h1>

        {%- if section.settings.description != blank -%}
          <div class="hero2__description">{{ section.settings.description }}</div>
        {%- endif -%}

        {%- if section.settings.button_text != blank or section.settings.button_text_2 != blank -%}
          <div class="hero2__buttons">
            {%- if section.settings.button_text != blank -%}
              <a href="{{ section.settings.button_link | default: '#' }}" class="hero2__btn hero2__btn--primary">
                {{ section.settings.button_text }}
              </a>
            {%- endif -%}
            {%- if section.settings.button_text_2 != blank -%}
              <a href="{{ section.settings.button_link_2 | default: '#' }}" class="hero2__btn hero2__btn--secondary">
                {%- if section.settings.button_2_show_icon -%}
                  <svg class="hero2__btn-icon" viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                {%- endif -%}
                {{ section.settings.button_text_2 }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <div class="hero2__media">
        {%- assign slider_blocks = section.blocks | where: 'type', 'slider_image' -%}
        {%- if slider_blocks.size > 0 -%}
          <div class="swiper hero2-swiper" id="hero2-swiper-{{ section.id }}" style="width: 100%; overflow: hidden;">
            <div class="swiper-wrapper">
              {%- for block in slider_blocks -%}
                {%- if block.settings.image -%}
                  <div class="swiper-slide" {{ block.shopify_attributes }}>
                    <img
                      class="hero2__image"
                      src="{{ block.settings.image | image_url: width: 1400 }}"
                      srcset="{{ block.settings.image | image_url: width: 700 }} 700w,
                              {{ block.settings.image | image_url: width: 1000 }} 1000w,
                              {{ block.settings.image | image_url: width: 1400 }} 1400w"
                      sizes="(min-width: 990px) 50vw, 100vw"
                      alt="{{ block.settings.image.alt | default: section.settings.title_line1 | escape }}"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                      loading="lazy"
                    >
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
            <div class="swiper-pagination"></div>
            <div class="swiper-button-prev"></div>
            <div class="swiper-button-next"></div>
          </div>
        {%- elsif section.settings.image -%}
          <img
            class="hero2__image"
            src="{{ section.settings.image | image_url: width: 1400 }}"
            srcset="{{ section.settings.image | image_url: width: 700 }} 700w,
                    {{ section.settings.image | image_url: width: 1000 }} 1000w,
                    {{ section.settings.image | image_url: width: 1400 }} 1400w"
            sizes="(min-width: 990px) 50vw, 100vw"
            alt="{{ section.settings.image.alt | default: section.settings.title_line1 | escape }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="eager"
          >
        {%- endif -%}
      </div>

    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="hero2__badges">
        {%- for block in section.blocks -%}
          {%- if block.type == 'badge' -%}
            <div class="hero2__badge" {{ block.shopify_attributes }}>
              {%- if block.settings.icon -%}
                <img
                  class="hero2__badge-icon"
                  src="{{ block.settings.icon | image_url: width: 60 }}"
                  alt=""
                  width="{{ block.settings.icon.width }}"
                  height="{{ block.settings.icon.height }}"
                  loading="lazy"
                >
              {%- endif -%}
              <span class="hero2__badge-text">
                {%- if block.settings.title != blank -%}
                  <span class="hero2__badge-title">{{ block.settings.title }}</span>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <span class="hero2__badge-description">{{ block.settings.description }}</span>
                {%- endif -%}
              </span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    --hero2-padding-top: {{ section.settings.padding_top }}px;
    --hero2-padding-bottom: {{ section.settings.padding_bottom }}px;
    --hero2-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --hero2-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --hero2-padding-horizontal: {{ section.settings.padding_horizontal }}px;
    --hero2-max-width: {{ section.settings.max_width }}px;
    --hero2-bg-color: {{ section.settings.bg_color }};
    --hero2-radius: {{ section.settings.section_radius }}px;

    --hero2-eyebrow-size: {{ section.settings.eyebrow_font_size }}px;
    --hero2-eyebrow-color: {{ section.settings.eyebrow_color }};
    --hero2-eyebrow-weight: {{ section.settings.eyebrow_font_weight }};

    --hero2-title-size: {{ section.settings.title_font_size }}px;
    --hero2-title-size-mobile: {{ section.settings.title_font_size_mobile }}px;
    --hero2-title-color: {{ section.settings.title_color }};
    --hero2-title-weight: {{ section.settings.title_font_weight }};

    --hero2-highlight-color: {{ section.settings.highlight_color }};

    --hero2-desc-size: {{ section.settings.description_font_size }}px;
    --hero2-desc-color: {{ section.settings.description_color }};
    --hero2-desc-weight: {{ section.settings.description_font_weight }};
    --hero2-desc-max-width: {{ section.settings.description_max_width }}px;

    --hero2-btn-padding-h: {{ section.settings.button_padding_horizontal }}px;
    --hero2-btn-padding-v: {{ section.settings.button_padding_vertical }}px;
    --hero2-btn-font-size: {{ section.settings.button_font_size }}px;
    --hero2-btn-color: {{ section.settings.button_color }};
    --hero2-btn-weight: {{ section.settings.button_font_weight }};
    --hero2-btn-bg: {{ section.settings.button_bg }};
    --hero2-btn-hover-bg: {{ section.settings.button_hover_bg }};

    --hero2-btn2-padding-h: {{ section.settings.button_2_padding_horizontal }}px;
    --hero2-btn2-padding-v: {{ section.settings.button_2_padding_vertical }}px;
    --hero2-btn2-font-size: {{ section.settings.button_2_font_size }}px;
    --hero2-btn2-color: {{ section.settings.button_2_color }};
    --hero2-btn2-weight: {{ section.settings.button_2_font_weight }};
    --hero2-btn2-bg: {{ section.settings.button_2_bg }};
    --hero2-btn2-hover-bg: {{ section.settings.button_2_hover_bg }};
    --hero2-btn2-border: {{ section.settings.button_2_border_color }};

    --hero2-badge-title-color: {{ section.settings.badge_title_color }};
    --hero2-badge-desc-color: {{ section.settings.badge_description_color }};
    --hero2-badge-divider-color: {{ section.settings.badge_divider_color }};

    --hero2-badge-icon-size: {{ section.settings.badge_icon_size }}px;
    --hero2-badge-icon-size-mobile: {{ section.settings.badge_icon_size_mobile }}px;
    --hero2-badge-title-size: {{ section.settings.badge_title_font_size }}px;
    --hero2-badge-title-size-mobile: {{ section.settings.badge_title_font_size_mobile }}px;
    --hero2-badge-desc-size: {{ section.settings.badge_description_font_size }}px;
    --hero2-badge-desc-size-mobile: {{ section.settings.badge_description_font_size_mobile }}px;

    --hero2-image-width: {{ section.settings.image_width }}%;
    --hero2-image-height: {{ section.settings.image_height }}px;
    --hero2-image-width-mobile: {{ section.settings.image_width_mobile }}%;
    --hero2-image-height-mobile: {{ section.settings.image_height_mobile }}px;

    background-color: var(--hero2-bg-color);
    {%- if section.settings.bg_image -%}
    background-image: url('{{ section.settings.bg_image | image_url: width: 2400 }}');
    background-size: cover;
    background-position: center;
    {%- endif -%}
    border-radius: var(--hero2-radius);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .hero2 {
    max-width: var(--hero2-max-width);
    margin: 0 auto;
    padding: var(--hero2-padding-top) var(--hero2-padding-horizontal) var(--hero2-padding-bottom);
  }

  #shopify-section-{{ section.id }} .hero2__grid {
    display: flex;
    align-items: center;
    gap: 40px;
  }

  #shopify-section-{{ section.id }} .hero2__content {
    flex: 1 1 440px;
    min-width: 300px;
  }

  #shopify-section-{{ section.id }} .hero2__media {
    flex: 1 1 440px;
    min-width: 0;
    max-width: 100%;
    display: flex;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .hero2__image {
    display: block;
    width: var(--hero2-image-width);
    height: var(--hero2-image-height);
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .hero2__eyebrow {
    font-size: var(--hero2-eyebrow-size);
    color: var(--hero2-eyebrow-color);
    font-weight: var(--hero2-eyebrow-weight);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0 0 16px;
  }

  #shopify-section-{{ section.id }} .hero2__title {
    font-size: var(--hero2-title-size-mobile);
    color: var(--hero2-title-color);
    font-weight: var(--hero2-title-weight);
    line-height: 1.2;
    margin: 0 0 20px;
  }

  #shopify-section-{{ section.id }} .hero2__title-highlight {
    color: var(--hero2-highlight-color);
    font-style: italic;
    font-family: Georgia, 'Times New Roman', serif;
    margin-right: 12px;
  }

  #shopify-section-{{ section.id }} .hero2__description {
    font-size: var(--hero2-desc-size);
    color: var(--hero2-desc-color);
    font-weight: var(--hero2-desc-weight);
    max-width: var(--hero2-desc-max-width);
    line-height: 1.6;
    margin: 0 0 32px;
  }

  #shopify-section-{{ section.id }} .hero2__description p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .hero2__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 40px;
  }

  #shopify-section-{{ section.id }} .hero2__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  #shopify-section-{{ section.id }} .hero2__btn--primary {
    padding: var(--hero2-btn-padding-v) var(--hero2-btn-padding-h);
    font-size: var(--hero2-btn-font-size);
    font-weight: var(--hero2-btn-weight);
    color: var(--hero2-btn-color);
    background-color: var(--hero2-btn-bg);
    border: 1px solid var(--hero2-btn-bg);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  #shopify-section-{{ section.id }} .hero2__btn--primary:hover {
    background-color: var(--hero2-btn-hover-bg);
    border-color: var(--hero2-btn-hover-bg);
  }

  #shopify-section-{{ section.id }} .hero2__btn--secondary {
    padding: var(--hero2-btn2-padding-v) var(--hero2-btn2-padding-h);
    font-size: var(--hero2-btn2-font-size);
    font-weight: var(--hero2-btn2-weight);
    color: var(--hero2-btn2-color);
    background-color: var(--hero2-btn2-bg);
    border: 1px solid var(--hero2-btn2-border);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  #shopify-section-{{ section.id }} .hero2__btn--secondary:hover {
    background-color: var(--hero2-btn2-hover-bg);
  }

  #shopify-section-{{ section.id }} .hero2__badges {
    display: flex;
    flex-wrap: wrap;
    column-gap: 48px;
    row-gap: 16px;
    margin-top: 32px;
  }

  #shopify-section-{{ section.id }} .hero2__badge {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .hero2__badge-icon {
    width: var(--hero2-badge-icon-size-mobile);
    height: var(--hero2-badge-icon-size-mobile);
    object-fit: contain;
    flex-shrink: 0;
  }

  #shopify-section-{{ section.id }} .hero2__badge-text {
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .hero2__badge-title {
    font-size: var(--hero2-badge-title-size-mobile);
    font-weight: 600;
    color: var(--hero2-badge-title-color);
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .hero2__badge-description {
    font-size: var(--hero2-badge-desc-size-mobile);
    color: var(--hero2-badge-desc-color);
    line-height: 1.3;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .hero2__title {
      font-size: var(--hero2-title-size);
    }

    #shopify-section-{{ section.id }} .hero2__badge-icon {
      width: var(--hero2-badge-icon-size);
      height: var(--hero2-badge-icon-size);
    }

    #shopify-section-{{ section.id }} .hero2__badge-title {
      font-size: var(--hero2-badge-title-size);
    }

    #shopify-section-{{ section.id }} .hero2__badge-description {
      font-size: var(--hero2-badge-desc-size);
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .hero2 {
      padding: var(--hero2-padding-top-mobile) var(--hero2-padding-horizontal) var(--hero2-padding-bottom-mobile);
    }

    #shopify-section-{{ section.id }} .hero2__grid {
      flex-direction: column-reverse;
      gap: 24px;
    }

    #shopify-section-{{ section.id }} .hero2__content,
    #shopify-section-{{ section.id }} .hero2__media {
      flex: 1 1 auto;
      min-width: 0;
    }

    #shopify-section-{{ section.id }} .hero2__badges {
      flex-direction: column;
      row-gap: 12px;
      margin-top: 20px;
    }

    #shopify-section-{{ section.id }} .hero2__image {
      width: var(--hero2-image-width-mobile);
      height: var(--hero2-image-height-mobile);
    }

    {%- if section.settings.bg_image_mobile -%}
    #shopify-section-{{ section.id }} {
      background-image: url('{{ section.settings.bg_image_mobile | image_url: width: 1200 }}');
    }
    {%- endif -%}
  }
</style>

<script>
  (function() {
    function initHeroSwiper() {
      var swiperContainer = document.querySelector('#hero2-swiper-{{ section.id }}');
      if (swiperContainer && typeof Swiper !== 'undefined') {
        // Destroy existing swiper if present to prevent multiple instances
        if (swiperContainer.swiper) {
          swiperContainer.swiper.destroy(true, true);
        }
        new Swiper(swiperContainer, {
          loop: true,
          autoplay: {
            delay: 5000,
            disableOnInteraction: false,
          },
          pagination: {
            el: swiperContainer.querySelector('.swiper-pagination'),
            clickable: true,
          },
          navigation: {
            nextEl: swiperContainer.querySelector('.swiper-button-next'),
            prevEl: swiperContainer.querySelector('.swiper-button-prev'),
          }
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHeroSwiper);
    } else {
      initHeroSwiper();
    }

    document.addEventListener('shopify:section:load', function(e) {
      if (e.detail.sectionId === '{{ section.id }}') {
        setTimeout(initHeroSwiper, 100);
      }
    });
    
    document.addEventListener('shopify:block:select', function(e) {
      if (e.detail.sectionId === '{{ section.id }}') {
        setTimeout(initHeroSwiper, 100);
      }
    });
    
    document.addEventListener('shopify:block:deselect', function(e) {
      if (e.detail.sectionId === '{{ section.id }}') {
        setTimeout(initHeroSwiper, 100);
      }
    });
  })();
</script>

