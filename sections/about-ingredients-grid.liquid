<div class="ingredients-section">
  <div class="ingredients">
    <div class="ingredients__header">
      {%- if section.settings.eyebrow_text != blank -%}
        <p class="ingredients__eyebrow">{{ section.settings.eyebrow_text }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2 class="ingredients__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="ingredients__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'item' -%}
            <div class="ingredients__item" {{ block.shopify_attributes }}>
              {%- if block.settings.image -%}
                <div class="ingredients__media" style="width:{{ block.settings.image_width }}%;margin-left:auto;margin-right:auto;">
                  <img
                    class="ingredients__image"
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                            {{ block.settings.image | image_url: width: 600 }} 600w,
                            {{ block.settings.image | image_url: width: 800 }} 800w"
                    sizes="(min-width: 750px) 33vw, 100vw"
                    alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                    loading="lazy"
                    style="height:{{ block.settings.image_height }}px;border-radius:{{ block.settings.image_radius }}px;{% if block.settings.enable_shadow %}box-shadow:0 16px 40px rgba(0,0,0,0.16);{% endif %}"
                  >
                </div>
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <p class="ingredients__item-title" style="font-size:{{ block.settings.title_font_size }}px;color:{{ block.settings.title_color }};font-weight:{{ block.settings.title_font_weight }};">{{ block.settings.title }}</p>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <div class="ingredients__item-description" style="font-size:{{ block.settings.description_font_size }}px;color:{{ block.settings.description_color }};font-weight:{{ block.settings.description_font_weight }};">{{ block.settings.description }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    --ing-padding-top: {{ section.settings.padding_top }}px;
    --ing-padding-bottom: {{ section.settings.padding_bottom }}px;
    --ing-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --ing-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --ing-padding-horizontal: {{ section.settings.padding_horizontal }}px;
    --ing-max-width: {{ section.settings.max_width }}px;
    --ing-bg-color: {{ section.settings.bg_color }};

    --ing-eyebrow-size: {{ section.settings.eyebrow_font_size }}px;
    --ing-eyebrow-color: {{ section.settings.eyebrow_color }};
    --ing-eyebrow-weight: {{ section.settings.eyebrow_font_weight }};

    --ing-title-size: {{ section.settings.title_font_size }}px;
    --ing-title-size-mobile: {{ section.settings.title_font_size_mobile }}px;
    --ing-title-color: {{ section.settings.title_color }};
    --ing-title-weight: {{ section.settings.title_font_weight }};

    background-color: var(--ing-bg-color);
  }

  #shopify-section-{{ section.id }} .ingredients {
    max-width: var(--ing-max-width);
    margin: 0 auto;
    padding: var(--ing-padding-top) var(--ing-padding-horizontal) var(--ing-padding-bottom);
  }

  #shopify-section-{{ section.id }} .ingredients__header {
    text-align: center;
    margin-bottom: 48px;
  }

  #shopify-section-{{ section.id }} .ingredients__eyebrow {
    font-size: var(--ing-eyebrow-size);
    color: var(--ing-eyebrow-color);
    font-weight: var(--ing-eyebrow-weight);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 12px;
  }

  #shopify-section-{{ section.id }} .ingredients__title {
    font-size: var(--ing-title-size-mobile);
    color: var(--ing-title-color);
    font-weight: var(--ing-title-weight);
    line-height: 1.2;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .ingredients__grid {
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
  }

  #shopify-section-{{ section.id }} .ingredients__item {
    flex: 1 1 280px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .ingredients__media {
    margin-bottom: 24px;
  }

  #shopify-section-{{ section.id }} .ingredients__image {
    display: block;
    width: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .ingredients__item-title {
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 10px;
  }

  #shopify-section-{{ section.id }} .ingredients__item-description {
    line-height: 1.6;
  }

  #shopify-section-{{ section.id }} .ingredients__item-description p {
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .ingredients__title {
      font-size: var(--ing-title-size);
    }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .ingredients {
      padding: var(--ing-padding-top-mobile) var(--ing-padding-horizontal) var(--ing-padding-bottom-mobile);
    }

    #shopify-section-{{ section.id }} .ingredients__grid {
      flex-direction: column;
      gap: 32px;
    }
  }
</style>

