{%- assign sec_id = section.id -%}

<style>
  .newsletter-social-{{ sec_id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_horizontal }}px;
    padding-right: {{ section.settings.padding_horizontal }}px;
    background-color: {{ section.settings.bg_color }};
  }

  .newsletter-social-{{ sec_id }} .ns-wrapper {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    row-gap: 24px;
  }

  /* Part 1: Icon + Title + Description */
  .newsletter-social-{{ sec_id }} .ns-info {
    display: flex;
    align-items: center;
    gap: 16px;
    flex: 0 1 auto;
  }

  .newsletter-social-{{ sec_id }} .ns-icon {
    flex-shrink: 0;
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    padding: {{ section.settings.icon_padding }}px;
    background-color: {{ section.settings.icon_bg }};
    border-radius: {{ section.settings.icon_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .newsletter-social-{{ sec_id }} .ns-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .newsletter-social-{{ sec_id }} .ns-title {
    font-size: {{ section.settings.title_font_size_desktop }}px;
    color: {{ section.settings.title_color }};
    font-weight: {{ section.settings.title_font_weight }};
    margin: 0 0 6px 0;
    line-height: 1.3;
  }

  .newsletter-social-{{ sec_id }} .ns-desc {
    font-size: {{ section.settings.desc_font_size }}px;
    color: {{ section.settings.desc_color }};
    font-weight: {{ section.settings.desc_font_weight }};
    max-width: {{ section.settings.desc_max_width }}px;
    margin: 0;
    line-height: 1.5;
  }

  /* Part 2: Form */
  .newsletter-social-{{ sec_id }} .ns-form {
    flex: 0 1 auto;
    display: flex;
    flex-wrap: nowrap;
    align-items: stretch;
    gap: 0;
    width: 100%;
    max-width: {{ section.settings.form_max_width }}px;
  }

  .newsletter-social-{{ sec_id }} .ns-form input[type="email"] {
    flex: 1 1 auto;
    min-width: 0;
    box-sizing: border-box;
    height: {{ section.settings.field_height }}px;
    font-size: {{ section.settings.input_font_size }}px;
    color: {{ section.settings.input_color }};
    background-color: {{ section.settings.input_bg }};
    border: {{ section.settings.input_border_width }}px solid {{ section.settings.input_border_color }};
    border-radius: {{ section.settings.input_radius }}px;
    padding: 0 16px;
    outline: none;
    margin: 0;
  }

  .newsletter-social-{{ sec_id }} .ns-form button {
    flex-shrink: 0;
    box-sizing: border-box;
    height: {{ section.settings.field_height }}px;
    padding: 0 {{ section.settings.btn_padding_horizontal }}px;
    font-size: {{ section.settings.btn_font_size }}px;
    color: {{ section.settings.btn_color }};
    font-weight: {{ section.settings.btn_font_weight }};
    background-color: {{ section.settings.btn_bg }};
    border: none;
    border-radius: {{ section.settings.input_radius }}px;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: background-color 0.25s ease;
    margin: 0 0 0 10px;
    line-height: 1;
  }

  .newsletter-social-{{ sec_id }} .ns-form button:hover {
    background-color: {{ section.settings.btn_hover_bg }};
  }

  /* Part 3: Follow Us */
  .newsletter-social-{{ sec_id }} .ns-social {
    flex: 0 1 auto;
  }

  .newsletter-social-{{ sec_id }} .ns-social-title {
    font-size: {{ section.settings.social_title_font_size_desktop }}px;
    color: {{ section.settings.social_title_color }};
    font-weight: {{ section.settings.social_title_font_weight }};
    margin: 0 0 12px 0;
  }

  .newsletter-social-{{ sec_id }} .ns-social-icons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .newsletter-social-{{ sec_id }} .ns-social-icon {
    width: {{ section.settings.social_icon_size }}px;
    height: {{ section.settings.social_icon_size }}px;
    padding: {{ section.settings.social_icon_padding }}px;
    background-color: {{ section.settings.social_icon_bg }};
    border-radius: {{ section.settings.social_icon_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.25s ease;
  }

  .newsletter-social-{{ sec_id }} .ns-social-icon:hover {
    background-color: {{ section.settings.social_icon_hover_bg }};
  }

  .newsletter-social-{{ sec_id }} .ns-social-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media screen and (max-width: 749px) {
    .newsletter-social-{{ sec_id }} .ns-title {
      font-size: {{ section.settings.title_font_size_mobile }}px;
    }
    .newsletter-social-{{ sec_id }} .ns-social-title {
      font-size: {{ section.settings.social_title_font_size_mobile }}px;
    }
    .newsletter-social-{{ sec_id }} .ns-wrapper {
      justify-content: center;
      text-align: center;
    }
    .newsletter-social-{{ sec_id }} .ns-info {
      justify-content: center;
    }
    .newsletter-social-{{ sec_id }} .ns-social {
      width: 100%;
      text-align: center;
    }
    .newsletter-social-{{ sec_id }} .ns-social-icons {
      justify-content: center;
    }
  }
</style>

<div class="newsletter-social-{{ sec_id }}">
  <div class="ns-wrapper">

    <!-- Part 1: Icon + Title + Description -->
    <div class="ns-info">
      {%- if section.settings.icon_image != blank -%}
        <div class="ns-icon">
          <img src="{{ section.settings.icon_image | image_url: width: 200 }}" alt="{{ section.settings.title | escape }}" loading="lazy">
        </div>
      {%- endif -%}
      <div class="ns-info-text">
        {%- if section.settings.title != blank -%}
          <p class="ns-title">{{ section.settings.title }}</p>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="ns-desc">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    </div>

    <!-- Part 2: Newsletter Form -->
    <div class="ns-form-wrap">
      {%- form 'customer', id: 'ns-newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="ns-form">
          <input type="email" name="contact[email]" placeholder="{{ section.settings.input_placeholder | escape }}" required>
          <button type="submit">{{ section.settings.button_label }}</button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="ns-form-success">{{ section.settings.success_message }}</p>
        {%- endif -%}
      {%- endform -%}
    </div>

    <!-- Part 3: Follow Us -->
    <div class="ns-social">
      {%- if section.settings.social_title != blank -%}
        <p class="ns-social-title">{{ section.settings.social_title }}</p>
      {%- endif -%}
      <div class="ns-social-icons">
        {%- for block in section.blocks -%}
          {%- if block.settings.icon_image != blank and block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="ns-social-icon" {% if block.settings.open_new_tab %}target="_blank" rel="noopener"{% endif %} {{ block.shopify_attributes }}>
              <img src="{{ block.settings.icon_image | image_url: width: 100 }}" alt="{{ block.settings.icon_image.alt | default: 'social icon' | escape }}" loading="lazy">
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  </div>
</div>

