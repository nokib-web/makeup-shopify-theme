{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .contact-layout-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
  
  @media screen and (min-width: 990px) {
    .contact-layout-{{ section.id }} {
      flex-direction: row;
      gap: 6rem;
    }
  }

  .contact-form-area-{{ section.id }} {
    flex: 1.5;
  }

  .contact-info-area-{{ section.id }} {
    flex: 1;
    background-color: {{ section.settings.card_bg_color }};
    padding: {{ section.settings.card_padding }}px;
    border: 1px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
  }

  /* Left Side: Form */
  .contact-form-badge-{{ section.id }} {
    display: inline-block;
    font-size: {{ section.settings.badge_font_size }}px;
    color: {{ section.settings.badge_color }};
    font-weight: {{ section.settings.badge_font_weight }};
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 1rem;
  }

  .contact-form-title-{{ section.id }} {
    font-size: {{ section.settings.title_font_size_mobile }}px;
    color: {{ section.settings.title_color }};
    font-weight: {{ section.settings.title_font_weight }};
    margin: 0 0 2rem 0;
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    .contact-form-title-{{ section.id }} {
      font-size: {{ section.settings.title_font_size_desktop }}px;
    }
  }

  .contact-form-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-form-row-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .contact-form-row-{{ section.id }} {
      flex-direction: row;
    }
    .contact-form-row-{{ section.id }} .field {
      flex: 1;
    }
  }

  .contact-form-{{ section.id }} .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-form-{{ section.id }} label {
    font-size: 14px;
    color: #333;
    font-weight: 500;
  }
  .contact-form-{{ section.id }} label span {
    color: red;
  }

  .contact-form-{{ section.id }} input,
  .contact-form-{{ section.id }} textarea {
    width: 100%;
    padding: {{ section.settings.field_padding }}px;
    font-size: {{ section.settings.field_font_size }}px;
    color: {{ section.settings.field_color }};
    background-color: {{ section.settings.field_bg_color }};
    border: 1px solid {{ section.settings.field_border_color }};
    border-radius: {{ section.settings.field_border_radius }}px;
    box-sizing: border-box;
    font-family: inherit;
  }
  
  .contact-form-{{ section.id }} textarea {
    resize: vertical;
    min-height: 150px;
  }

  .contact-form-{{ section.id }} button {
    align-self: flex-start;
    cursor: pointer;
    border: none;
    padding: {{ section.settings.btn_padding_vertical }}px {{ section.settings.btn_padding_horizontal }}px;
    font-size: {{ section.settings.btn_font_size }}px;
    color: {{ section.settings.btn_color }};
    font-weight: {{ section.settings.btn_font_weight }};
    background-color: {{ section.settings.btn_bg_color }};
    transition: background-color 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: 1rem;
  }

  .contact-form-{{ section.id }} button:hover {
    background-color: {{ section.settings.btn_hover_bg_color }};
  }

  /* Right Side: Info */
  .contact-info-title-{{ section.id }} {
    font-size: {{ section.settings.info_title_font_size }}px;
    color: {{ section.settings.info_title_color }};
    font-weight: {{ section.settings.info_title_font_weight }};
    margin: 0 0 2rem 0;
  }

  .contact-info-list-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact-info-item-{{ section.id }} {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .contact-info-icon-{{ section.id }} {
    width: {{ section.settings.info_icon_width }}px;
    height: {{ section.settings.info_icon_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.info_icon_bg }};
    border-radius: 50%;
    flex-shrink: 0;
  }
  
  .contact-info-icon-{{ section.id }} svg, .contact-info-icon-{{ section.id }} img {
    width: 50%;
    height: 50%;
    object-fit: contain;
  }

  .contact-info-content-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .contact-info-content-{{ section.id }} h4 {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    color: #333;
  }

  .contact-info-content-{{ section.id }} p {
    margin: 0;
    font-size: 14px;
    color: #555;
    line-height: 1.5;
  }

  .contact-social-icons-{{ section.id }} {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .contact-social-icons-{{ section.id }} a {
    color: #333;
    display: inline-flex;
  }
  
  .contact-social-icons-{{ section.id }} a svg {
    width: 20px;
    height: 20px;
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="contact-layout-{{ section.id }}">
    
    <!-- Left Form Area -->
    <div class="contact-form-area-{{ section.id }}" id="contact-form-section">
      {%- if section.settings.badge_text != blank -%}
        <div class="contact-form-badge-{{ section.id }}">{{ section.settings.badge_text }}</div>
      {%- endif -%}
      
      {%- if section.settings.title_text != blank -%}
        <h2 class="contact-form-title-{{ section.id }}">{{ section.settings.title_text }}</h2>
      {%- endif -%}
      
      {%- assign form_class = 'contact-form-' | append: section.id -%}
      {%- form 'contact', class: form_class -%}
        {%- if form.posted_successfully? -%}
          <p class="form-status form-status-list form__message" tabindex="-1" autofocus>
            Thanks for contacting us. We'll get back to you as soon as possible.
          </p>
        {%- elsif form.errors -%}
          <div class="form__message">
            <h2 class="form-status caption-large text-body" role="alert" tabindex="-1" autofocus>
              Please adjust the following:
            </h2>
          </div>
          <ul class="form-status-list caption-large" role="list">
            <li>
              <a href="#ContactForm-email" class="link">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}
              </a>
            </li>
          </ul>
        {%- endif -%}

        <div class="contact-form-row-{{ section.id }}">
          <div class="field">
            <label for="ContactForm-name">Your Name <span>*</span></label>
            <input type="text" id="ContactForm-name" name="contact[name]" required placeholder="">
          </div>
          <div class="field">
            <label for="ContactForm-email">Email Address <span>*</span></label>
            <input type="email" id="ContactForm-email" name="contact[email]" required placeholder="">
          </div>
        </div>
        
        <div class="field">
          <label for="ContactForm-subject">Subject <span>*</span></label>
          <input type="text" id="ContactForm-subject" name="contact[subject]" required placeholder="">
        </div>
        
        <div class="field">
          <label for="ContactForm-body">Your Message <span>*</span></label>
          <textarea id="ContactForm-body" name="contact[body]" required placeholder=""></textarea>
        </div>
        
        <button type="submit">{{ section.settings.btn_text }}</button>
      {%- endform -%}
    </div>

    <!-- Right Info Area -->
    <div class="contact-info-area-{{ section.id }}">
      {%- if section.settings.info_title != blank -%}
        <h3 class="contact-info-title-{{ section.id }}">{{ section.settings.info_title }}</h3>
      {%- endif -%}
      
      <div class="contact-info-list-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'info_item' -%}
              <div class="contact-info-item-{{ section.id }}" {{ block.shopify_attributes }}>
                <div class="contact-info-icon-{{ section.id }}">
                  {%- if block.settings.icon_svg != blank -%}
                    {{ block.settings.icon_svg }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag }}
                  {%- endif -%}
                </div>
                <div class="contact-info-content-{{ section.id }}">
                  {%- if block.settings.title != blank -%}
                    <h4>{{ block.settings.title }}</h4>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <div>{{ block.settings.text }}</div>
                  {%- endif -%}
                </div>
              </div>
              
            {%- when 'social_item' -%}
              <div class="contact-info-item-{{ section.id }}" {{ block.shopify_attributes }}>
                <div class="contact-info-icon-{{ section.id }}">
                   {%- if block.settings.icon_svg != blank -%}
                    {{ block.settings.icon_svg }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag }}
                  {%- endif -%}
                </div>
                <div class="contact-info-content-{{ section.id }}">
                  {%- if block.settings.title != blank -%}
                    <h4>{{ block.settings.title }}</h4>
                  {%- endif -%}
                  <div class="contact-social-icons-{{ section.id }}">
                    <!-- Using placeholder icons for socials to keep it simple, or user can add them via theme settings -->
                    {%- if settings.social_instagram_link != blank -%}
                      <a href="{{ settings.social_instagram_link }}" target="_blank">
                        <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-instagram" viewBox="0 0 512 512"><path d="M256,49.471c67.266,0,75.233.257,101.8,1.469,24.562,1.121,37.9,5.224,46.778,8.674a78.052,78.052,0,0,1,28.966,18.845,78.052,78.052,0,0,1,18.845,28.966c3.45,8.877,7.554,22.216,8.674,46.778,1.212,26.565,1.469,34.532,1.469,101.8s-0.257,75.233-1.469,101.8c-1.121,24.562-5.224,37.9-8.674,46.778a83.427,83.427,0,0,1-47.811,47.811c-8.877,3.45-22.216,7.554-46.778,8.674-26.56,1.212-34.527,1.469-101.8,1.469s-75.237-.257-101.8-1.469c-24.562-1.121-37.9-5.224-46.778-8.674a78.052,78.052,0,0,1-28.966-18.845,78.052,78.052,0,0,1-18.845-28.966c-3.45-8.877-7.554-22.216-8.674-46.778-1.212-26.565-1.469-34.532-1.469-101.8s0.257-75.233,1.469-101.8c1.121-24.562,5.224-37.9,8.674-46.778A78.052,78.052,0,0,1,78.458,78.458a78.052,78.052,0,0,1,28.966-18.845c8.877-3.45,22.216-7.554,46.778-8.674,26.56-1.212,34.527-1.469,101.8-1.469m0-45.391c-68.418,0-77,.29-103.866,1.516-26.815,1.224-45.127,5.482-61.151,11.71a123.488,123.488,0,0,0-44.62,29.057A123.488,123.488,0,0,0,17.3,90.982C11.077,107.007,6.819,125.319,5.6,152.134,4.37,178.995,4.08,187.582,4.08,256S4.37,333.005,5.6,359.866c1.224,26.815,5.482,45.127,11.71,61.151a123.488,123.488,0,0,0,29.057,44.62,123.488,123.488,0,0,0,44.62,29.057c16.025,6.228,34.337,10.486,61.151,11.71,26.87,1.226,35.449,1.516,103.866,1.516s77-.29,103.866-1.516c26.815-1.224,45.127-5.482,61.151-11.71a128.817,128.817,0,0,0,73.677-73.677c6.228-16.025,10.486-34.337,11.71-61.151,1.226-26.87,1.516-35.449,1.516-103.866s-0.29-77-1.516-103.866c-1.224-26.815-5.482-45.127-11.71-61.151a123.488,123.488,0,0,0-29.057-44.62A123.488,123.488,0,0,0,421.018,17.3C404.993,11.077,386.681,6.819,359.866,5.6,333.005,4.37,324.418,4.08,256,4.08Z" fill="currentColor"/><path d="M256,126.636A129.364,129.364,0,1,0,385.364,256,129.364,129.364,0,0,0,256,126.636Zm0,213.336A83.973,83.973,0,1,1,339.973,256,83.973,83.973,0,0,1,256,339.973Z" fill="currentColor"/><circle cx="390.476" cy="121.524" r="30.23" fill="currentColor"/></svg>
                      </a>
                    {%- endif -%}
                    {%- if settings.social_facebook_link != blank -%}
                      <a href="{{ settings.social_facebook_link }}" target="_blank">
                        <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-facebook" viewBox="0 0 18 18"><path d="M16.42.61c.27 0 .5.1.69.28.19.2.28.42.28.7v15.44c0 .27-.1.5-.28.69a.94.94 0 01-.7.28h-4.39v-6.7h2.25l.31-2.65h-2.56v-1.7c0-.4.1-.72.28-.93.18-.2.5-.32 1-.32h1.37V3.35c-.6-.06-1.27-.1-2.01-.1-1.14 0-2.05.3-2.73.9-.68.6-1.03 1.5-1.03 2.67v1.9H6.97v2.65h1.93V18H.98c-.28 0-.5-.1-.7-.28a.94.94 0 01-.28-.7V1.59c0-.28.1-.5.28-.69a.94.94 0 01.7-.28h15.44z" fill="currentColor"/></svg>
                      </a>
                    {%- endif -%}
                    <a href="#">
                      <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-tiktok" viewBox="0 0 2859 3333"><path d="M2081 0c55 473 319 750 778 785v532c-266 26-499-61-770-225v995c0 1264-1378 1659-1932 753C-237 2137 361 1133 1332 1216v567c-502-38-765 423-448 831 228 295 723 273 723-380V0h474z" fill="currentColor"/></svg>
                    </a>
                  </div>
                </div>
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Contact Form & Info",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1200
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Left: Form Headings"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "SEND US A MESSAGE"
    },
    {
      "type": "range",
      "id": "badge_font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Badge Font Size",
      "default": 12
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge Color",
      "default": "#888888"
    },
    {
      "type": "range",
      "id": "badge_font_weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "label": "Badge Font Weight",
      "default": 600
    },
    {
      "type": "text",
      "id": "title_text",
      "label": "Form Title",
      "default": "How Can We Help?"
    },
    {
      "type": "range",
      "id": "title_font_size_desktop",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title Font Size Desktop",
      "default": 40
    },
    {
      "type": "range",
      "id": "title_font_size_mobile",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Title Font Size Mobile",
      "default": 28
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "title_font_weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "label": "Title Font Weight",
      "default": 400
    },
    {
      "type": "header",
      "content": "Form Fields"
    },
    {
      "type": "range",
      "id": "field_padding",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Field Padding",
      "default": 15
    },
    {
      "type": "range",
      "id": "field_font_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Field Font Size",
      "default": 14
    },
    {
      "type": "color",
      "id": "field_color",
      "label": "Field Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "field_bg_color",
      "label": "Field Background Color",
      "default": "#fdfaf7"
    },
    {
      "type": "color",
      "id": "field_border_color",
      "label": "Field Border Color",
      "default": "#e6e6e6"
    },
    {
      "type": "range",
      "id": "field_border_radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Field Border Radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Submit Button"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "SEND MESSAGE"
    },
    {
      "type": "range",
      "id": "btn_padding_vertical",
      "min": 5,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Button Padding Vertical",
      "default": 15
    },
    {
      "type": "range",
      "id": "btn_padding_horizontal",
      "min": 10,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Button Padding Horizontal",
      "default": 30
    },
    {
      "type": "range",
      "id": "btn_font_size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Button Font Size",
      "default": 12
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "btn_font_weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "label": "Button Font Weight",
      "default": 700
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "btn_hover_bg_color",
      "label": "Button Hover Background Color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Right: Contact Info Card"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color",
      "default": "#fdfaf7"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",
      "default": "transparent"
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Card Padding",
      "default": 50
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Card Border Radius",
      "default": 0
    },
    {
      "type": "text",
      "id": "info_title",
      "label": "Info Title",
      "default": "Contact Information"
    },
    {
      "type": "range",
      "id": "info_title_font_size",
      "min": 16,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Info Title Font Size",
      "default": 24
    },
    {
      "type": "color",
      "id": "info_title_color",
      "label": "Info Title Color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "info_title_font_weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "label": "Info Title Font Weight",
      "default": 400
    },
    {
      "type": "range",
      "id": "info_icon_width",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Icon Wrapper Width",
      "default": 48
    },
    {
      "type": "range",
      "id": "info_icon_height",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Icon Wrapper Height",
      "default": 48
    },
    {
      "type": "color",
      "id": "info_icon_bg",
      "label": "Icon Wrapper Background",
      "default": "#f2ede7"
    }
  ],
  "blocks": [
    {
      "type": "info_item",
      "name": "Info Item",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
