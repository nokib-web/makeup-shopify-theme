{% comment %}
  Bestseller Product Carousel Section
  Rare Beauty Style Product Carousel Section with Full-Width Side Card Peeking & Rich Metafields Data
{% endcomment %}

{%- assign section_bg = section.settings.section_bg_color -%}
{%- assign card_bg = section.settings.card_bg_color -%}

{% if section.settings.enable_overlay %}
  {% assign section_overlay = 'dt-sc-overlay' %}
{% endif %}

<div class="dt-sc-section-wrapper {{ section_overlay }} bestseller-section-wrapper" id="bestseller-section-{{ section.id }}">
  
  {% comment %} Native Theme Section Header (Centered in Standard Container) {% endcomment %}
  <div class="{% render 'container-settings' %}">
    <div class="row {{ section.settings.custom_class_name }}">
      {% render 'section-heading', class: section.id %} 
    </div>
  </div>

  {% comment %} Full Width Carousel Outer Container for Side Card Peeking {% endcomment %}
  <div class="bestseller-full-width-container">
    <div class="bestseller-carousel-outer">
      
      {% comment %} Left Navigation Arrow (Middle Left) {% endcomment %}
      {%- if section.settings.show_arrows -%}
        <div class="bestseller-arrow-prev bestseller-swiper-prev-{{ section.id }}" aria-label="Previous">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </div>
      {%- endif -%}

      <div class="swiper-container bestseller-swiper-{{ section.id }}" data-section-id="{{ section.id }}">
        <div class="swiper-wrapper">
          
          {% comment %} Render Blocks if Added {% endcomment %}
          {%- if section.blocks.size > 0 -%}
            {%- for block in section.blocks -%}
              {%- case block.type -%}
                
                {% comment %} PRODUCT BLOCK {% endcomment %}
                {%- when 'product' -%}
                  {%- assign product = all_products[block.settings.product] -%}
                  <div class="swiper-slide bestseller-card-slide" {{ block.shopify_attributes }}>
                    {%- if product != blank -%}
                      {%- render 'bestseller-card-markup', product: product, block: block, section: section -%}
                    {%- else -%}
                      {%- render 'bestseller-demo-card-markup', index: forloop.index, block: block, section: section -%}
                    {%- endif -%}
                  </div>

                {% comment %} COLLECTION BLOCK {% endcomment %}
                {%- when 'collection' -%}
                  {%- assign collection = collections[block.settings.collection] -%}
                  {%- if collection != blank and collection.products_count > 0 -%}
                    {%- for product in collection.products limit: block.settings.products_limit -%}
                      <div class="swiper-slide bestseller-card-slide" {{ block.shopify_attributes }}>
                        {%- render 'bestseller-card-markup', product: product, block: nil, section: section -%}
                      </div>
                    {%- endfor -%}
                  {%- else -%}
                    {%- for i in (1..8) -%}
                      <div class="swiper-slide bestseller-card-slide" {{ block.shopify_attributes }}>
                        {%- render 'bestseller-demo-card-markup', index: i, block: nil, section: section -%}
                      </div>
                    {%- endfor -%}
                  {%- endif -%}

              {%- endcase -%}
            {%- endfor -%}

          {%- else -%}
            
            {% comment %} FALLBACK IF NO BLOCKS ADDED {% endcomment %}
            {%- assign main_collection = collections[section.settings.collection] -%}
            {%- if main_collection != blank and main_collection.products_count > 0 -%}
              {%- for product in main_collection.products limit: section.settings.products_to_show -%}
                <div class="swiper-slide bestseller-card-slide">
                  {%- render 'bestseller-card-markup', product: product, block: nil, section: section -%}
                </div>
              {%- endfor -%}
            {%- else -%}
              {%- for i in (1..8) -%}
                <div class="swiper-slide bestseller-card-slide">
                  {%- render 'bestseller-demo-card-markup', index: i, block: nil, section: section -%}
                </div>
              {%- endfor -%}
            {%- endif -%}

          {%- endif -%}

        </div>

        {%- if section.settings.show_dots -%}
          <div class="swiper-pagination bestseller-swiper-pagination-{{ section.id }}"></div>
        {%- endif -%}

      </div>

      {% comment %} Right Navigation Arrow (Middle Right) {% endcomment %}
      {%- if section.settings.show_arrows -%}
        <div class="bestseller-arrow-next bestseller-swiper-next-{{ section.id }}" aria-label="Next">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </div>
      {%- endif -%}

    </div>
  </div>

</div>

<style>
  #bestseller-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section_bg }};
    width: 100%;
    overflow: hidden;
  }

  /* Centered Section Heading with SINGLE Background Image (No Repeat) */
  #bestseller-section-{{ section.id }} .dt-sc-heading {
    text-align: center !important;
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    margin-left: auto !important;
    margin-right: auto !important;
    margin-bottom: {{ section.settings.header_margin_bottom }}px !important;
    position: relative !important;
  }

  /* Disable Duplicate :after Background Image */
  #bestseller-section-{{ section.id }} .dt-sc-heading:after {
    display: none !important;
  }

  /* Single Centered :before Background Image */
  #bestseller-section-{{ section.id }} .dt-sc-heading:before {
    left: 50% !important;
    transform: translateX(-50%) !important;
    margin-left: 0 !important;
    background-repeat: no-repeat !important;
    background-position: center !important;
    background-size: contain !important;
  }

  #bestseller-section-{{ section.id }} .dt-sc-main-heading {
    text-align: center !important;
  }

  /* Full Width Container */
  .bestseller-full-width-container {
    width: 100%;
    max-width: 100%;
    padding: 0;
    margin: 0;
  }

  /* Carousel Outer Layout with Full-Width Edge Padding */
  .bestseller-carousel-outer {
    position: relative;
    padding: 0 50px;
    overflow: hidden;
    width: 100%;
  }

  .bestseller-swiper-{{ section.id }} {
    overflow: visible !important;
    position: relative;
    padding: 10px 0 30px 0;
  }

  /* BASE SLIDE STYLE: Faded (0.4) on side peeking cards extending past main 4 columns */
  .bestseller-swiper-{{ section.id }} .swiper-slide {
    height: auto;
    opacity: 0.4;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  /* THE 4 MAIN VISIBLE CARDS IN THE MIDDLE GRID ARE 100% NORMAL & SOLID (Opacity 1) */
  .bestseller-swiper-{{ section.id }} .swiper-slide.swiper-slide-visible {
    opacity: 1 !important;
  }

  /* Middle Left and Middle Right Navigation Arrows */
  .bestseller-arrow-prev,
  .bestseller-arrow-next {
    position: absolute;
    top: 42%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: #FFFFFF;
    color: #222222;
    box-shadow: 0 4px 14px rgba(0,0,0,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 25;
    border: 1px solid rgba(0,0,0,0.08);
    transition: all 0.25s ease;
  }

  .bestseller-arrow-prev { left: 4px; }
  .bestseller-arrow-next { right: 4px; }

  .bestseller-arrow-prev:hover,
  .bestseller-arrow-next:hover {
    background-color: var(--DTPrimaryColor, #6B3B43);
    color: #FFFFFF;
    transform: translateY(-50%) scale(1.08);
  }

  .bestseller-arrow-prev.swiper-button-disabled,
  .bestseller-arrow-next.swiper-button-disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  /* Product Card Styling */
  .bestseller-product-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: {{ section.settings.card_border_radius }}px;
    overflow: hidden;
    background-color: {{ card_bg }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .bestseller-image-link {
    display: block;
    text-decoration: none;
    overflow: hidden;
  }

  .bestseller-image-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ section.settings.image_bg_color }};
  }

  .bestseller-image-wrapper.ratio-1-1 { aspect-ratio: 1 / 1; }
  .bestseller-image-wrapper.ratio-3-4 { aspect-ratio: 3 / 4; }
  .bestseller-image-wrapper.ratio-4-5 { aspect-ratio: 4 / 5; }
  .bestseller-image-wrapper.ratio-adapt { height: auto; min-height: 280px; }

  .bestseller-image-wrapper img, 
  .bestseller-image-wrapper svg {
    width: 100%;
    height: 100%;
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .bestseller-image-wrapper img.image-fit-contain,
  .bestseller-image-wrapper svg {
    object-fit: contain;
    padding: 16px;
  }

  .bestseller-image-wrapper img.image-fit-cover {
    object-fit: cover;
  }

  .bestseller-secondary-img {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
  }

  .bestseller-product-card:hover .bestseller-secondary-img {
    opacity: 1;
  }

  .bestseller-product-card:hover .bestseller-primary-img {
    {%- if section.settings.show_secondary_image -%}
      opacity: 0;
    {%- else -%}
      transform: scale(1.03);
    {%- endif -%}
  }

  /* Card Content Info & Metafields Support */
  .bestseller-card-info {
    padding: 14px 0 8px 0;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .bestseller-product-title {
    font-family: var(--DTFontTypo_Heading, serif);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.35;
    margin: 0 0 6px 0;
    color: var(--DTColor_Heading, #222);
  }

  .bestseller-product-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .bestseller-product-title a:hover {
    color: var(--DTPrimaryColor);
  }

  /* Rating Stars & Review Count */
  .bestseller-card-rating {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 6px;
    font-size: 13px;
  }

  .bestseller-stars {
    color: #FFA41C;
    letter-spacing: 1px;
    font-size: 13px;
  }

  .bestseller-rating-count {
    color: #007185;
    font-size: 12px;
    font-weight: 500;
  }

  /* Custom Badge (#1 Best Seller) */
  .bestseller-card-badge-wrap {
    margin-bottom: 6px;
  }

  .bestseller-card-badge {
    display: inline-block;
    background-color: #C64B00;
    color: #FFFFFF;
    font-size: 10px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Offer / Price Subtitle Line */
  .bestseller-card-offer {
    font-size: 12px;
    color: #565959;
    margin-bottom: 6px;
    font-weight: 500;
  }

  /* Feature / Sustainability Line */
  .bestseller-card-feature {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    color: #2e7d32;
    margin-bottom: 8px;
    font-weight: 500;
  }

  /* Swatches */
  .bestseller-swatch-container {
    margin-bottom: 10px;
  }

  .bestseller-swatch-label {
    display: block;
    font-family: var(--DTFontTypo_Body, sans-serif);
    font-size: 11px;
    font-weight: 600;
    color: var(--DTColor_Body, #333);
    opacity: 0.85;
    margin-bottom: 4px;
    text-transform: capitalize;
    min-height: 15px;
  }

  .bestseller-swatch-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }

  .bestseller-swatch-btn {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: none;
    padding: 0;
    cursor: pointer;
    position: relative;
    outline: none;
    box-shadow: inset 0 0 0 1px rgba(0,0,0,0.15);
    transition: transform 0.15s ease, outline-color 0.15s ease;
    background-position: center;
    background-size: cover;
  }

  .bestseller-swatch-btn.active {
    outline: 1.5px solid var(--DTPrimaryColor, #6B3B43);
    outline-offset: 2.5px;
  }

  .bestseller-swatch-btn:hover {
    transform: scale(1.1);
  }

  /* Action Form & Native Primary Theme Buttons */
  .bestseller-action-form {
    margin-top: auto;
  }

  .bestseller-add-form {
    margin: 0;
  }

  .bestseller-add-btn.dt-sc-btn {
    width: 100%;
    margin-top: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 11px;
    padding: 8px 10px;
  }

  .btn-price-separator {
    margin: 0 4px;
  }

  @media (max-width: 991px) {
    .bestseller-carousel-outer { padding: 0 35px; }
    .bestseller-arrow-prev { left: 0px; }
    .bestseller-arrow-next { right: 0px; }
  }

  @media (max-width: 767px) {
    .bestseller-carousel-outer { padding: 0 25px; }
    #bestseller-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.7 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.7 }}px;
    }
    .bestseller-arrow-prev, .bestseller-arrow-next { width: 36px; height: 36px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var sectionId = "{{ section.id }}";
    var containerSelector = '.bestseller-swiper-' + sectionId;
    
    function initBestsellerSwiper() {
      if (typeof Swiper === 'undefined') {
        setTimeout(initBestsellerSwiper, 100);
        return;
      }

      var swiper = new Swiper(containerSelector, {
        slidesPerView: 1.2,
        spaceBetween: {{ section.settings.item_space }},
        loop: {{ section.settings.enable_loop }},
        watchSlidesProgress: true,
        watchSlidesVisibility: true,
        autoplay: {% if section.settings.enable_autoplay %}{ delay: {{ section.settings.autoplay_speed }} * 1000 }{% else %}false{% endif %},
        navigation: {
          nextEl: '.bestseller-swiper-next-' + sectionId,
          prevEl: '.bestseller-swiper-prev-' + sectionId,
        },
        pagination: {
          el: '.bestseller-swiper-pagination-' + sectionId,
          clickable: true,
        },
        breakpoints: {
          640: {
            slidesPerView: 2.4,
            spaceBetween: {{ section.settings.item_space }}
          },
          992: {
            slidesPerView: 3.4,
            spaceBetween: {{ section.settings.item_space }}
          },
          1200: {
            slidesPerView: 4.5,
            spaceBetween: {{ section.settings.item_space }}
          }
        }
      });
    }

    initBestsellerSwiper();

    // Swatch Click Event Handler
    var sectionElement = document.getElementById('bestseller-section-' + sectionId);
    if (sectionElement) {
      sectionElement.addEventListener('click', function (event) {
        var swatchBtn = event.target.closest('.bestseller-swatch-btn');
        if (!swatchBtn) return;

        var card = swatchBtn.closest('.bestseller-product-card');
        if (!card) return;

        // 1. Update Active Ring
        var allSwatches = card.querySelectorAll('.bestseller-swatch-btn');
        allSwatches.forEach(function (btn) { btn.classList.remove('active'); });
        swatchBtn.classList.add('active');

        // 2. Update Shade Name Text
        var shadeTitle = swatchBtn.getAttribute('data-variant-title');
        var labelElem = card.querySelector('.bestseller-swatch-label');
        if (labelElem && shadeTitle) {
          labelElem.textContent = shadeTitle;
        }

        // 3. Update Image
        var newImgUrl = swatchBtn.getAttribute('data-variant-image');
        var primaryImg = card.querySelector('.bestseller-primary-img');
        if (primaryImg && newImgUrl) {
          primaryImg.src = newImgUrl;
        }

        // 4. Update Variant ID for Form
        var variantId = swatchBtn.getAttribute('data-variant-id');
        var hiddenInput = card.querySelector('.bestseller-selected-variant-id');
        if (hiddenInput && variantId) {
          hiddenInput.value = variantId;
        }

        // 5. Update Price on Button
        var variantPrice = swatchBtn.getAttribute('data-variant-price');
        var priceElem = card.querySelector('.btn-price-value');
        if (priceElem && variantPrice) {
          priceElem.textContent = variantPrice;
        }
      });
    }
  });
</script>

{% comment %} Schema Definition {% endcomment %}
{% schema %}
{
  "name": "Bestseller Carousel",
  "class": "index-section bestseller-carousel-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Heading Settings"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Heading",
      "default": "Bestsellers"
    },
    {
      "type": "text",
      "id": "section_sub_heading",
      "label": "Sub Heading"
    },
    {
      "type": "textarea",
      "id": "section_description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "section_button_text",
      "label": "Shop Link Label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "section_button_link",
      "label": "Shop Link URL",
      "default": "/collections/all"
    },
    {
      "type": "select",
      "id": "heading_position",
      "label": "Heading Position",
      "options": [
        { "value": "text-center", "label": "Center" },
        { "value": "text-start", "label": "Left" },
        { "value": "text-end", "label": "Right" }
      ],
      "default": "text-center"
    },
    {
      "type": "header",
      "content": "Collection Settings (If No Blocks Added)"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 3,
      "max": 16,
      "step": 1,
      "label": "Maximum Products to Show",
      "default": 10
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image Aspect Ratio",
      "options": [
        { "value": "1-1", "label": "Square (1:1)" },
        { "value": "3-4", "label": "Portrait (3:4)" },
        { "value": "4-5", "label": "Portrait (4:5)" },
        { "value": "adapt", "label": "Adapt to Image" }
      ],
      "default": "1-1"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image Fit Mode",
      "options": [
        { "value": "contain", "label": "Contain (Uncropped)" },
        { "value": "cover", "label": "Cover (Fill Space)" }
      ],
      "default": "contain"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "label": "Show Secondary Image on Hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Rich Card Details & Metafields"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show Star Ratings & Review Count",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show Badge (#1 Best Seller)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_offer",
      "label": "Show Offer Subtitle Line",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_feature",
      "label": "Show Sustainability / Feature Line",
      "default": true
    },
    {
      "type": "header",
      "content": "Swatches & Button Settings"
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "Enable Color/Shade Swatches",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_swatch_name",
      "label": "Show Active Shade Name Label",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Action Button Label",
      "default": "ADD TO BAG"
    },
    {
      "type": "checkbox",
      "id": "show_button_price",
      "label": "Show Variant Price on Button",
      "default": true
    },
    {
      "type": "header",
      "content": "Carousel Layout Settings"
    },
    {
      "type": "range",
      "id": "item_space",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Space Between Cards",
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Navigation Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Pagination Dots",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_loop",
      "label": "Enable Infinite Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Autoplay Delay",
      "default": 4
    },
    {
      "type": "header",
      "content": "Color & Styling Settings"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background",
      "default": "#FAF6F0"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#FAF6F0"
    },
    {
      "type": "color",
      "id": "image_bg_color",
      "label": "Image Wrapper Background",
      "default": "#F6F2EE"
    },
    {
      "type": "header",
      "content": "Section Padding & Container"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Card Border Radius",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Top Padding",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 20,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "text",
          "id": "custom_title",
